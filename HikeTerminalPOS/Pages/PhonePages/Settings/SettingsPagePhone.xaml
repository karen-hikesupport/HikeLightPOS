<?xml version="1.0" encoding="UTF-8"?>
<local:BaseContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HikePOS.SettingsPagePhone"
             xmlns:local="clr-namespace:HikePOS"
             xmlns:resources="clr-namespace:HikePOS.Resources"
             xmlns:Localize="clr-namespace:HikePOS;assembly=HikePOS"
             xmlns:userControls="clr-namespace:HikePOS.UserControls"
             xmlns:vm="clr-namespace:HikePOS.ViewModels"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:TypeArguments="vm:SettingsViewModel"
             xmlns:model="clr-namespace:HikePOS.Models"
             x:DataType="vm:SettingsViewModel"
             xmlns:Helpers="clr-namespace:HikePOS.Helpers"
             Title="{Binding Title}">
    <ContentPage.Content>
        <Grid BackgroundColor="{x:Static resources:AppColors.MainBackgroundColor}" VerticalOptions="FillAndExpand"   RowSpacing="0" ColumnSpacing="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="{OnPlatform iOS='44', Android='48'}"/>
                <RowDefinition Height="2" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <ContentView BackgroundColor="White" Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3" />
            <StackLayout Grid.Row="2" Grid.Column="0"  x:Name="GeneralAutoLockTab" IsVisible="false" VerticalOptions="StartAndExpand" Padding="10,70,10,40" Spacing="0" TranslationX="-9999999999">
                <Grid ColumnSpacing="5" RowSpacing="0" VerticalOptions="Start">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="{OnPlatform iOS='44', Android='50'}"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackLayout Grid.Column="0" Grid.Row="0" Orientation="Horizontal" Spacing="0" VerticalOptions="FillAndExpand">
                        <Label Text="{Localize:Translate BackIconUnicode}" Style="{x:Static resources:Styles.PageBackLabelStyle}" Padding="10,0,0,0" />
                        <Button Text="{Localize:Translate Back_ButtonText}" Style="{x:Static resources:Styles.PageBackButtonStyle}" Clicked="BackHandle_Clicked"/>
                    </StackLayout>
                </Grid>
                <Border Style="{x:Static resources:Styles.SettingsAutoHeightRoundBorderStyle}" Padding="0" Margin="0,10,0,0">
                    <CollectionView x:Name="AutoLockListView" ItemsSource="{Binding AutoLockDurationList}" HeightRequest="420"  SelectionMode="Single" SelectionChanged="AutoLockDuration_ItemTapped">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="model:AutoLockDurationModel">
                                <Grid VerticalOptions="FillAndExpand" HorizontalOptions="FillAndExpand" RowDefinitions="69.5,0.5" RowSpacing="0" Padding="20,0,20,0" HeightRequest="70">
                                    <StackLayout Grid.Row="0" VerticalOptions="FillAndExpand" HorizontalOptions="FillAndExpand" Orientation="Horizontal">
                                        <Label Text="{Binding Title}" Style="{x:Static resources:Styles.SettingsOptionTitleLabelStyle}" />
                                        <Image Source="check_icon" IsVisible="{Binding IsSelected}" HeightRequest="20" WidthRequest="20" VerticalOptions="Center" HorizontalOptions="End" />
                                    </StackLayout>
                                    <BoxView Grid.Row="1" IsVisible="{Binding IsNotLast}" VerticalOptions="End" Style="{StaticResource HalfHeightBoxViewLine}" />
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </Border>
                <StackLayout.Triggers>
                    <DataTrigger TargetType="StackLayout" Binding="{Binding SelectedMenuItem}" Value="GENERAL">
                        <Setter Property="IsVisible" Value="True" />
                    </DataTrigger>
                </StackLayout.Triggers>
            </StackLayout>
            <ScrollView  Grid.Row="2" Grid.Column="0" Margin="0,0,0,30"  x:Name="GeneralTab" >
                <StackLayout VerticalOptions="FillAndExpand" IsVisible="false" Padding="10,30,10,40" Spacing="0">
                    <Border IsVisible="false"  Style="{x:Static resources:Styles.SettingsGeneralRoundBorderStyle}" Padding="20,0,20,0" Margin="0,42,0,0">
                        <StackLayout VerticalOptions="FillAndExpand" HorizontalOptions="FillAndExpand" Orientation="Horizontal" HeightRequest="70">
                            <Label Text="{Localize:Translate MarkPaidOrderOptionLabelText}" Style="{x:Static resources:Styles.SettingsOptionTitleLabelStyle}" />
                            <userControls:CustomSwitch HorizontalOptions="End" VerticalOptions="Center" IsToggled="{Binding ActiveMarkPaidOrderAsFulfilled}" >
                                <userControls:CustomSwitch.Behaviors>
                                    <toolkit:EventToCommandBehavior
                                EventName="Toggled"
                                Command="{Binding MarkAsPaidSwitchToggleCommand}" />
                                </userControls:CustomSwitch.Behaviors>
                            </userControls:CustomSwitch>
                        </StackLayout>
                    </Border>
                    <Label IsVisible="false" Text="{Localize:Translate MarkPaidOrderOptionDescriptionText}" Style="{x:Static resources:Styles.SettingsOptionDescriptionLabelStyle}" />
                    <Border Style="{x:Static resources:Styles.SettingsGeneralRoundBorderStyle}" Padding="20,0,20,0"  Margin="0,42,0,0">
                        <StackLayout VerticalOptions="FillAndExpand" HorizontalOptions="FillAndExpand" Orientation="Horizontal" Spacing="10">
                            <Label Text="{Localize:Translate AutoLockOptionLabelText}" Style="{x:Static resources:Styles.SettingsOptionTitleLabelStyle}" HorizontalOptions="Start" />
                            <Label Text="{Binding AutoLockDuration}" Style="{x:Static resources:Styles.SettingsOptionTitleLabelStyle}" TextColor="{x:Static resources:AppColors.PlaceholderColor}" HorizontalTextAlignment="End" />
                            <Image Source="{x:Static resources:AppImages.RightArrowIcon}" HeightRequest="20" WidthRequest="20" VerticalOptions="Center" HorizontalOptions="End" />
                            <StackLayout.GestureRecognizers>
                                <TapGestureRecognizer Tapped="ShowAutoLockOptionHandle_Tapped" />
                            </StackLayout.GestureRecognizers>
                        </StackLayout>
                    </Border>
                    <Label Text="{Localize:Translate AutoLockOptionDescriptionText}" Style="{x:Static resources:Styles.SettingsOptionDescriptionLabelStyle}" />
                    <Border Style="{x:Static resources:Styles.SettingsGeneralRoundBorderStyle}" Padding="20,0,20,0">
                        <StackLayout VerticalOptions="FillAndExpand" HorizontalOptions="FillAndExpand" Orientation="Horizontal">
                            <Label Text="{Localize:Translate SyncDataOptionLabelText}" Style="{x:Static resources:Styles.SettingsOptionTitleLabelStyle}" />
                            <Button Text="{Localize:Translate SyncDataButtonText}" Command="{Binding SyncDataCommand}" Style="{x:Static resources:Styles.SettingsDataSyncButtonStyle}" />
                            <!--<Button Text="{Localize:Translate ClearSyncDataButtonText}" Command="{Binding ClearAndSyncDataCommand}" Style="{x:Static resources:Styles.SettingsDataSyncButtonStyle}" />-->
                        </StackLayout>
                    </Border>
                    <Label Text="{Localize:Translate SyncDataOptionDescriptionText}" Style="{x:Static resources:Styles.SettingsOptionDescriptionLabelStyle}" />
                    <Border Style="{x:Static resources:Styles.SettingsGeneralRoundBorderStyle}" Padding="20,0,20,0">
                        <StackLayout VerticalOptions="FillAndExpand" HorizontalOptions="FillAndExpand" Orientation="Horizontal">
                            <Label Text="{Localize:Translate ClearSyncDataOptionLabelText}" Style="{x:Static resources:Styles.SettingsOptionTitleLabelStyle}" />
                            <Button Text="{Localize:Translate ClearSyncDataButtonText}" Command="{Binding ClearAndSyncDataCommand}" Style="{x:Static resources:Styles.SettingsDataSyncButtonStyle}" />
                        </StackLayout>
                    </Border>
                    <Label Text="{Localize:Translate ClearSyncDataOptionDescriptionText}" Style="{x:Static resources:Styles.SettingsOptionDescriptionLabelStyle}" />
                    <Border Style="{x:Static resources:Styles.SettingsGeneralRoundBorderStyle}" Padding="20,0,20,0">
                        <StackLayout VerticalOptions="FillAndExpand" HorizontalOptions="FillAndExpand" Orientation="Horizontal">
                            <Label Text="{Localize:Translate ExportLogLabelText}" Style="{x:Static resources:Styles.SettingsOptionTitleLabelStyle}" />
                            <Button x:Name="btnExport" Text="{Localize:Translate ExportLogButtonText}" Command="{Binding ExportLogCommand}"
                                CommandParameter="{Binding Source={RelativeSource Self}}" Style="{x:Static resources:Styles.SettingsDataSyncButtonStyle}" />
                        </StackLayout>
                    </Border>
                    <Label Text="{Localize:Translate ExportLogDescriptionText}" Style="{x:Static resources:Styles.SettingsOptionDescriptionLabelStyle}" />
                    <StackLayout.Triggers>
                        <DataTrigger TargetType="StackLayout" Binding="{Binding SelectedMenuItem}" Value="GENERAL">
                            <Setter Property="IsVisible" Value="True" />
                        </DataTrigger>
                    </StackLayout.Triggers>
                </StackLayout>
            </ScrollView>
            <!-- End general tab view -->
            <!-- End general tab-->
            <!-- Start hardware tab-->
            <!-- Start select docket number slider view-->
            <StackLayout Grid.Row="2" Grid.Column="0" x:Name="HardwareDocketNumberRangeTab" IsVisible="false" VerticalOptions="FillAndExpand" Padding="10,70,10,40" Spacing="0" TranslationX="-9999999999">
                <Grid ColumnSpacing="5" RowSpacing="0" VerticalOptions="Start">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="{OnPlatform iOS='44', Android='50'}"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackLayout Grid.Column="0" Grid.Row="0" Orientation="Horizontal" Spacing="0" VerticalOptions="FillAndExpand">
                        <Label Text="{Localize:Translate BackIconUnicode}" Style="{x:Static resources:Styles.PageBackLabelStyle}" Padding="10,0,0,0"/>
                        <Button Text="{Localize:Translate Back_ButtonText}" Style="{x:Static resources:Styles.PageBackButtonStyle}" Clicked="BackHandle_Clicked" />
                    </StackLayout>
                </Grid>
                <Border Style="{x:Static resources:Styles.SettingsAutoHeightRoundBorderStyle}" Padding="0" Margin="0,10,0,0">
                    <CollectionView x:Name="DocketNumberListView" ItemsSource="{Binding DocketNumberRangeList}" HeightRequest="350" SelectionMode="Single" SelectionChanged="DocketNumberListView_SelectionChanged">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="model:AutoLockDurationModel">
                               <Grid VerticalOptions="FillAndExpand" HorizontalOptions="FillAndExpand" RowDefinitions="69.5,0.5" RowSpacing="0" Padding="20,0,20,0" HeightRequest="70">
                                    <StackLayout Grid.Row="0" VerticalOptions="FillAndExpand" HorizontalOptions="FillAndExpand" Orientation="Horizontal">
                                        <Label Text="{Binding Title}" Style="{x:Static resources:Styles.SettingsOptionTitleLabelStyle}" />
                                        <Image Source="check_icon" IsVisible="{Binding IsSelected}" HeightRequest="20" WidthRequest="20" VerticalOptions="Center" HorizontalOptions="End" />
                                    </StackLayout>
                                    <BoxView Grid.Row="1" IsVisible="{Binding IsNotLast}" VerticalOptions="End" Style="{StaticResource HalfHeightBoxViewLine}" />
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </Border>
                <StackLayout.Triggers>
                    <DataTrigger TargetType="StackLayout" Binding="{Binding SelectedMenuItem}" Value="PRINTER">
                        <Setter Property="IsVisible" Value="True" />
                    </DataTrigger>
                </StackLayout.Triggers>
            </StackLayout>
            <!-- End select docket number slider view-->
            <!-- Start select no of copies slider view-->
            <StackLayout Grid.Row="2" Grid.Column="0" x:Name="HardwarePrinterNoOfCopiesTab" IsVisible="false" VerticalOptions="FillAndExpand" Padding="10,70,10,40" Spacing="0" TranslationX="-9999999999">
                <Grid ColumnSpacing="5" RowSpacing="0" BackgroundColor="White" VerticalOptions="Start">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="{OnPlatform iOS='44', Android='50'}"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackLayout Grid.Column="0" Grid.Row="0" Orientation="Horizontal" Spacing="0" VerticalOptions="FillAndExpand">
                        <Label Text="{Localize:Translate BackIconUnicode}" Style="{x:Static resources:Styles.PageBackLabelStyle}" Padding="10,0,0,0"/>
                        <Button Text="{Localize:Translate Back_ButtonText}" Style="{x:Static resources:Styles.PageBackButtonStyle}" Clicked="BackHandle_Clicked" />
                    </StackLayout>
                </Grid>
                <Border Style="{x:Static resources:Styles.SettingsAutoHeightRoundBorderStyle}" Padding="0" Margin="0,10,0,0">
                    <CollectionView x:Name="NoOfCopiesListView" ItemsSource="{Binding NoOfCopiesList}" HeightRequest="350" SelectionChanged="NoOfCopies_ItemTapped" SelectionMode="Single">
                        <CollectionView.ItemTemplate>
                            <DataTemplate  x:DataType="model:AutoLockDurationModel">
                                <Grid VerticalOptions="FillAndExpand" HorizontalOptions="FillAndExpand" RowDefinitions="69.5,0.5" RowSpacing="0" Padding="20,0,20,0" HeightRequest="70">
                                    <StackLayout Grid.Row="0" VerticalOptions="FillAndExpand" HorizontalOptions="FillAndExpand" Orientation="Horizontal">
                                        <Label Text="{Binding Title}" Style="{x:Static resources:Styles.SettingsOptionTitleLabelStyle}" />
                                        <Image Source="check_icon" IsVisible="{Binding IsSelected}" HeightRequest="22" WidthRequest="22" VerticalOptions="Center" HorizontalOptions="End" />
                                    </StackLayout>
                                    <BoxView Grid.Row="1" IsVisible="{Binding IsNotLast}" VerticalOptions="End" Style="{StaticResource HalfHeightBoxViewLine}" />
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </Border>
                <StackLayout.Triggers>
                    <DataTrigger TargetType="StackLayout" Binding="{Binding SelectedMenuItem}" Value="PRINTER">
                        <Setter Property="IsVisible" Value="True" />
                    </DataTrigger>
                </StackLayout.Triggers>
            </StackLayout>
            <!-- End select no of copies slider view-->
            <!-- Start printer configuration slider view-->
            <StackLayout Grid.Row="2" Grid.Column="0"  x:Name="HardwarePrinterTab" VerticalOptions="FillAndExpand" HorizontalOptions="FillAndExpand" IsVisible="false" TranslationX="-9999999999" Padding="10,70,10,0" Spacing="0">
                <Grid ColumnSpacing="5" RowSpacing="0" VerticalOptions="Start">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="{OnPlatform iOS='44', Android='50'}"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackLayout Grid.Column="0" Grid.Row="0" Orientation="Horizontal" Spacing="0" VerticalOptions="FillAndExpand">
                        <Label Text="{Localize:Translate BackIconUnicode}" Style="{x:Static resources:Styles.PageBackLabelStyle}" Padding="10,0,0,0"/>
                        <Button Text="{Localize:Translate Back_ButtonText}" Style="{x:Static resources:Styles.PageBackButtonStyle}" Clicked="BackHandle_Clicked" />
                    </StackLayout>
                </Grid>
                <StackLayout VerticalOptions="FillAndExpand" HorizontalOptions="FillAndExpand" Padding="-40,0,0,0">
                    <ScrollView VerticalOptions="FillAndExpand" HorizontalOptions="FillAndExpand" >
                        <StackLayout VerticalOptions="FillAndExpand" HorizontalOptions="FillAndExpand" Spacing="0" Padding="40,0,0,0">
                            <Border Style="{x:Static resources:Styles.SettingsAutoHeightRoundBorderStyle}" Padding="0" Margin="0,42,0,0">
                                <StackLayout VerticalOptions="FillAndExpand" HorizontalOptions="FillAndExpand" Spacing="0" Padding="20,0,20,0">
                                    <StackLayout VerticalOptions="FillAndExpand" HorizontalOptions="FillAndExpand" Orientation="Horizontal" HeightRequest="70">
                                        <Label Text="{Localize:Translate PrimaryReceiptPrinterLabelText}" Style="{x:Static resources:Styles.SettingsOptionTitleLabelStyle}" />
                                        <userControls:CustomSwitch HorizontalOptions="End" VerticalOptions="Center" IsToggled="{Binding SelectedPrinter.PrimaryReceiptPrint}" >
                                            <userControls:CustomSwitch.Behaviors>
                                                <toolkit:EventToCommandBehavior
                                                   EventName="Toggled"
                                                   Command="{Binding UpdatePrinterToggledCommand}" />
                                            </userControls:CustomSwitch.Behaviors>
                                        </userControls:CustomSwitch>
                                    </StackLayout>
                                    <BoxView VerticalOptions="End" Style="{StaticResource HalfHeightBoxViewLine}" />
                                    <StackLayout VerticalOptions="FillAndExpand" HorizontalOptions="FillAndExpand" Orientation="Horizontal" HeightRequest="70">
                                        <Label Text="{Localize:Translate DocketPrinterLabelText}" Style="{x:Static resources:Styles.SettingsOptionTitleLabelStyle}" />
                                        <userControls:CustomSwitch HorizontalOptions="End" VerticalOptions="Center" IsToggled="{Binding SelectedPrinter.ActiveDocketPrint}" >
                                            <userControls:CustomSwitch.Behaviors>
                                                <toolkit:EventToCommandBehavior
                                                   EventName="Toggled"
                                                   Command="{Binding UpdatePrinterToggledCommand}" />
                                            </userControls:CustomSwitch.Behaviors>
                                        </userControls:CustomSwitch>
                                    </StackLayout>
                                </StackLayout>
                            </Border>
                            <Label Text="{Localize:Translate PrimaryDocketDescriptionText}" Style="{x:Static resources:Styles.SettingsOptionDescriptionLabelStyle}" />
                            <Border Style="{x:Static resources:Styles.SettingsAutoHeightRoundBorderStyle}" Padding="0">
                                <StackLayout VerticalOptions="FillAndExpand" HorizontalOptions="FillAndExpand" Spacing="0" Padding="20,0,20,0">
                                    <StackLayout VerticalOptions="FillAndExpand" HorizontalOptions="FillAndExpand" Orientation="Horizontal" Spacing="10" HeightRequest="71">
                                        <Label Text="{Localize:Translate NoOfCopiesLabelText}" Style="{x:Static resources:Styles.SettingsOptionTitleLabelStyle}" HorizontalOptions="Start" />
                                        <Label Text="{Binding SelectedPrinter.NumberOfPrintCopy, StringFormat='{0} copy'}" Style="{x:Static resources:Styles.SettingsOptionTitleLabelStyle}" TextColor="{x:Static resources:AppColors.PlaceholderColor}" HorizontalTextAlignment="End" />
                                        <Image Source="{x:Static resources:AppImages.RightArrowIcon}" HeightRequest="22" WidthRequest="22" VerticalOptions="Center" HorizontalOptions="End" />
                                        <StackLayout.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="ShowNoOfCopiesOptionHandle_Tapped" />
                                        </StackLayout.GestureRecognizers>
                                    </StackLayout>
                                    <BoxView VerticalOptions="End" Style="{StaticResource HalfHeightBoxViewLine}" />
                                    <StackLayout VerticalOptions="FillAndExpand" HorizontalOptions="FillAndExpand" Orientation="Horizontal" HeightRequest="70.5">
                                        <Label Text="{Localize:Translate AutoPrintLabelText}" Style="{x:Static resources:Styles.SettingsOptionTitleLabelStyle}" />
                                        <userControls:CustomSwitch HorizontalOptions="End" VerticalOptions="Center" IsToggled="{Binding SelectedPrinter.IsAutoPrintReceipt}" >
                                            <userControls:CustomSwitch.Behaviors>
                                                <toolkit:EventToCommandBehavior
                                                   EventName="Toggled"
                                                   Command="{Binding UpdatePrinterToggledCommand}" />
                                            </userControls:CustomSwitch.Behaviors>
                                        </userControls:CustomSwitch>
                                    </StackLayout>
                                    <BoxView VerticalOptions="End" Style="{StaticResource HalfHeightBoxViewLine}" />
                                    <StackLayout VerticalOptions="FillAndExpand" HorizontalOptions="FillAndExpand" Orientation="Horizontal" HeightRequest="70.5">
                                        <Label Text="{Localize:Translate EnableAutoOpenCashDrawerLabelText}" Style="{x:Static resources:Styles.SettingsOptionTitleLabelStyle}" />
                                        <userControls:CustomSwitch HorizontalOptions="End" VerticalOptions="Center" IsToggled="{Binding SelectedPrinter.EnableCashDrawer}" >
                                            <userControls:CustomSwitch.Behaviors>
                                                <toolkit:EventToCommandBehavior
                                                   EventName="Toggled"
                                                   Command="{Binding UpdatePrinterToggledCommand}" />
                                            </userControls:CustomSwitch.Behaviors>
                                        </userControls:CustomSwitch>
                                    </StackLayout>
                                    <BoxView VerticalOptions="End" Style="{StaticResource HalfHeightBoxViewLine}" />
                                    <StackLayout VerticalOptions="FillAndExpand" HorizontalOptions="FillAndExpand" Orientation="Horizontal" HeightRequest="71">
                                        <Label Text="{Localize:Translate EnableAutoOpenCashDrawerOnlyCashSalesLabelText}" Style="{x:Static resources:Styles.SettingsOptionTitleLabelStyle}" />
                                        <userControls:CustomSwitch HorizontalOptions="End" VerticalOptions="Center" IsToggled="{Binding SelectedPrinter.OnlyCashPaymentCashDrawer}" >
                                            <userControls:CustomSwitch.Behaviors>
                                                <toolkit:EventToCommandBehavior
                                                   EventName="Toggled"
                                                   Command="{Binding UpdatePrinterToggledCommand}" />
                                            </userControls:CustomSwitch.Behaviors>
                                        </userControls:CustomSwitch>
                                    </StackLayout>
                                </StackLayout>
                            </Border>
                            <!--Ticket starts #70775:The client wants to connect  usb scanner to mc3 print in ipad.by rupesh-->
                            <Border IsVisible="{Binding SelectedPrinter.ShowEnableUSBScanner}" Style="{x:Static resources:Styles.SettingsAutoHeightRoundBorderStyle}" Padding="0" Margin="0,20,0,0">
                                <StackLayout VerticalOptions="FillAndExpand" HorizontalOptions="FillAndExpand" Orientation="Horizontal" HeightRequest="70" Spacing="0" Padding="20,0,20,0">
                                    <Label Text="Enable USB Barcode Scanner" Style="{x:Static resources:Styles.SettingsOptionTitleLabelStyle}" />
                                    <userControls:CustomSwitch  HorizontalOptions="End" VerticalOptions="Center" IsToggled="{Binding SelectedPrinter.EnableUSBScanner}" Toggled="UpdatePrinterFromSwitchHandle_Toggled"/>
                                </StackLayout>
                            </Border>
                            <!--Ticket end #70775:.by rupesh-->
                            <Border Style="{x:Static resources:Styles.SettingsAutoHeightRoundBorderStyle}" Padding="0" Margin="0,20,0,0">
                                <StackLayout VerticalOptions="FillAndExpand" HorizontalOptions="FillAndExpand" Spacing="0" Padding="20,0,20,0">
                                    <StackLayout VerticalOptions="FillAndExpand" HorizontalOptions="FillAndExpand" Orientation="Horizontal" HeightRequest="70">
                                        <Label Text="{Localize:Translate AllCloudReceiptLabelText}" Style="{x:Static resources:Styles.SettingsOptionTitleLabelStyle}" />
                                        <userControls:CustomSwitch HorizontalOptions="End" VerticalOptions="Center" IsToggled="{Binding ActiveAllCoudReceipt}" >
                                            <userControls:CustomSwitch.Behaviors>
                                                <toolkit:EventToCommandBehavior
                                                   EventName="Toggled"
                                                   Command="{Binding AllCloudReceiptCommand}" />
                                            </userControls:CustomSwitch.Behaviors>
                                        </userControls:CustomSwitch>
                                    </StackLayout>
                                    <BoxView IsVisible="{Binding ActiveAllCoudReceipt}" VerticalOptions="End" Style="{StaticResource HalfHeightBoxViewLine}" />
                                    <StackLayout IsVisible="{Binding ActiveAllCoudReceipt}" VerticalOptions="FillAndExpand" HorizontalOptions="FillAndExpand" Orientation="Horizontal" HeightRequest="70">
                                        <Label Text="{Localize:Translate AllCloudReceiptQRCodeLabelText}" Style="{x:Static resources:Styles.SettingsOptionTitleLabelStyle}" />
                                        <userControls:CustomSwitch HorizontalOptions="End" VerticalOptions="Center" IsToggled="{Binding SelectedPrinter.CloudQRCode}" >
                                            <userControls:CustomSwitch.Behaviors>
                                                <toolkit:EventToCommandBehavior
                                                   EventName="Toggled"
                                                   Command="{Binding UpdatePrinterToggledCommand}" />
                                            </userControls:CustomSwitch.Behaviors>
                                        </userControls:CustomSwitch>
                                    </StackLayout>
                                    <BoxView IsVisible="{Binding ActiveAllCoudReceipt}" VerticalOptions="End" Style="{StaticResource HalfHeightBoxViewLine}" />
                                    <StackLayout IsVisible="{Binding ActiveAllCoudReceipt}" VerticalOptions="FillAndExpand" HorizontalOptions="FillAndExpand" Orientation="Horizontal" HeightRequest="70">
                                        <Label Text="{Localize:Translate AllCloudReceiptInfoLabelText}" Style="{x:Static resources:Styles.SettingsOptionTitleLabelStyle}" />
                                        <userControls:CustomSwitch HorizontalOptions="End" VerticalOptions="Center" IsToggled="{Binding SelectedPrinter.CloudInfoCode}" >
                                            <userControls:CustomSwitch.Behaviors>
                                                <toolkit:EventToCommandBehavior
                                                   EventName="Toggled"
                                                   Command="{Binding UpdatePrinterToggledCommand}" />
                                            </userControls:CustomSwitch.Behaviors>
                                        </userControls:CustomSwitch>
                                    </StackLayout>
                                </StackLayout>
                            </Border>
                            <Label Style="{x:Static resources:Styles.SettingsOptionDescriptionLabelStyle}">
                                <Label.FormattedText>
                                    <FormattedString>
                                        <Span Text="{Localize:Translate AllCloudReceiptDescriptionText}" />
                                        <Span Text="{Localize:Translate AllCloudReceiptDescriptionLinkButtonText}" TextColor="Blue" />
                                    </FormattedString>
                                </Label.FormattedText>
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding AllReceiptDescriptionLinkCommand}"/>
                                </Label.GestureRecognizers>
                            </Label>
                        </StackLayout>
                    </ScrollView>
                </StackLayout>
                <StackLayout.Triggers>
                    <DataTrigger TargetType="StackLayout" Binding="{Binding SelectedMenuItem}" Value="PRINTER">
                        <Setter Property="IsVisible" Value="True" />
                    </DataTrigger>
                </StackLayout.Triggers>
            </StackLayout>
            <!-- End printer configuration slider view-->
            <!-- Start hardware view-->
            <StackLayout Grid.Row="2" Grid.Column="0" x:Name="HardwareTab" IsVisible="false" VerticalOptions="FillAndExpand" Padding="10,10,10,40" Spacing="0">
                <Grid ColumnSpacing="5" RowSpacing="0" VerticalOptions="Start">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="{OnPlatform iOS='44', Android='50'}"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackLayout Grid.Column="0" Grid.Row="0" Orientation="Horizontal" Spacing="2" VerticalOptions="FillAndExpand">
                        <!--<Label  Text="{Localize:Translate BackIconUnicode}" Style="{x:Static resources:Styles.PageBackLabelStyle}" />
                        <Button Text="{Localize:Translate Back_ButtonText}" Style="{x:Static resources:Styles.PageBackButtonStyle}" Clicked="BackHandle_Clicked"/>-->
                    </StackLayout>
                </Grid>
                <Border Style="{x:Static resources:Styles.SettingsAutoHeightRoundBorderStyle}" Padding="0" Margin="0,10,0,0">
                    <StackLayout VerticalOptions="FillAndExpand" HorizontalOptions="FillAndExpand" Spacing="0" Padding="20,0,20,0">
                        <StackLayout VerticalOptions="FillAndExpand" HorizontalOptions="FillAndExpand" Orientation="Horizontal" HeightRequest="70">
                            <Label Text="{Localize:Translate ActivePrinterLabelText}" Style="{x:Static resources:Styles.SettingsOptionTitleLabelStyle}" />
                            <userControls:CustomSwitch HorizontalOptions="End" VerticalOptions="Center" IsToggled="{Binding ActivePrinter}"
                                                       >
                                <userControls:CustomSwitch.Behaviors>
                                    <toolkit:EventToCommandBehavior
                                            EventName="Toggled"
                                            Command="{Binding ActivePrinterToggleCommand}" />
                                </userControls:CustomSwitch.Behaviors>
                            </userControls:CustomSwitch>
                        </StackLayout>
                        <ActivityIndicator IsVisible="{Binding IsLoad}" Scale="{x:OnPlatform iOS='1', Android='0.7'}" IsRunning="{Binding IsLoad}" Color="{x:Static resources:AppColors.HikeColor}" HorizontalOptions="Center"/>
                        <StackLayout x:Name="PrinterListView" BindableLayout.ItemsSource="{Binding PrinterList}" IsVisible="{Binding ActivePrinter}" Margin="-20,0,-20,0">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="model:Printer">
                                    <StackLayout VerticalOptions="FillAndExpand" HeightRequest="80"
                                                     HorizontalOptions="FillAndExpand" Spacing="0" Padding="20,0,20,0">
                                        <BoxView VerticalOptions="End" Style="{StaticResource HalfHeightBoxViewLine}" />
                                        <StackLayout VerticalOptions="FillAndExpand" HorizontalOptions="FillAndExpand" Orientation="Horizontal" Spacing="10">
                                            <StackLayout Orientation="Vertical">
                                                <Label Text="{Binding ModelName}" Style="{x:Static resources:Styles.SettingsOptionTitleLabelStyle}" HorizontalOptions="Start" />
                                                <Label Text="{Binding Port}" Margin="0,-40,0,0" Style="{x:Static resources:Styles.SettingsOptionTitleLabelStyle}" FontSize="12" HorizontalOptions="Start" />
                                            </StackLayout>
