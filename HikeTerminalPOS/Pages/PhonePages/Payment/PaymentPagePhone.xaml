                        </Grid>

                        <StackLayout Grid.Row="3" Spacing="10" IsVisible="{Binding IsPayment_GiftCardVisible}" Margin="10,0,10,0" >
                            <Label x:Name="GiftcardLabel" Text="{Binding GiftcardLabelText}"  Style="{x:Static resources:Styles.PaymentGroupHeaderLabelStyle}" HorizontalTextAlignment="Start" />
                            <Border Style="{x:Static resources:Styles.FormRoundBorderStyle}" HeightRequest="60" Padding="0" VerticalOptions="Start">
                                <Grid ColumnSpacing="0" RowSpacing="0" >
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="6*" />
                                        <ColumnDefinition Width="4*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="60" />
                                    </Grid.RowDefinitions>
                                    <userControls:BorderLessEntry x:Name="GiftCardUserEntry" IsEnabled="{Binding IsGiftCardUserEntryEnabled}"
                                                                  Text="{Binding Payment_GiftCardNumber}" Grid.Row="0" Grid.Column="0" VerticalOptions="Center"
                                                                  Placeholder ="{Binding GiftCardUserEntryHint}" Style="{x:Static resources:Styles.PaymentGiftNumberEntryStyle}">
                                    <userControls:BorderLessEntry.Behaviors>
                                      <toolkit:EventToCommandBehavior
                                          EventName="TextChanged"
                                          Command="{Binding GiftCardHandleCommand}"
                                          CommandParameter="{x:Reference GiftCardUserEntry}"  />
                                      <toolkit:EventToCommandBehavior
                                          EventName="Focused"
                                          Command="{Binding GiftCardHandleFocusedCommand}"/>
                                      <toolkit:EventToCommandBehavior
                                          EventName="Unfocused"
                                          Command="{Binding GiftCardHandleUnFocusedCommand}"/>
                                     </userControls:BorderLessEntry.Behaviors>
                                    </userControls:BorderLessEntry>
                                    <Button Grid.Row="0"  x:Name="GiftCardAfterPayButton" Grid.Column="1" IsEnabled="{Binding IsGiftCardAfterPayButtonEnabled}"
                                            Text="{Localize:Translate ChargeText}" Command="{Binding GiftCardChargeHandleCommand}"
                                            Style="{x:Static resources:Styles.PaymentGiftChargeButtonStyle}" VerticalOptions="FillAndExpand"
                                            HorizontalOptions="FillAndExpand" >
                                              <!--Start #90944 iOS:FR Gift cards expiry date by Pratik-->
                                            <Button.Triggers>
                                                <DataTrigger TargetType="Button" Binding="{Binding IsGiftCardAfterPayButtonEnabled}" Value="False">
                                                    <Setter Property="Background" Value="{x:Static resources:AppColors.ItemBackgroundColor}" />
                                                </DataTrigger>
                                                <DataTrigger TargetType="Button" Binding="{Binding IsGiftCardAfterPayButtonEnabled}" Value="True">
                                                    <Setter Property="Background" Value="{x:Static resources:AppColors.HikeColor}" />
                                                </DataTrigger>
                                            </Button.Triggers>
                                            <!--End #90944 by Pratik-->
                                    </Button>
                                </Grid>
                            </Border>
                            <Label Text="{Binding GiftCardBalance}" Style="{x:Static resources:Styles.PaymentGroupHeaderLabelStyle}" HorizontalTextAlignment="Start" VerticalOptions="Start"/>
                        </StackLayout>
