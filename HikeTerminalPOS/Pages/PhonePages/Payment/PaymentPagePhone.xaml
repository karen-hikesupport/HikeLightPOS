                               <!--Command="{Binding Source={x:Reference POListView}, Path=BindingContext.CreatePOCommand}" CommandParameter="{Binding .}"-->
                            <CollectionView Grid.Row="1" x:Name="lstViewPaymentList" 
                                    VerticalOptions="StartAndExpand"
                                    ItemSizingStrategy="MeasureFirstItem"
                                    HorizontalOptions="FillAndExpand" 
                                    HeightRequest = "{Binding PaymentListHeight}"
                                    ItemsSource="{Binding PaymentOptionList}" Margin="10,0,10,0" >
                                <CollectionView.ItemsLayout>
                                     <GridItemsLayout Orientation="Vertical" Span="1" VerticalItemSpacing="5" HorizontalItemSpacing="5"/> 
                                </CollectionView.ItemsLayout>
                                <CollectionView.ItemTemplate>
                                    <DataTemplate x:DataType="model:PaymentOptionDto">
                                        <!--Start ticket #73190 iOS FR :Automatic Surcharge For Card Payment ONLY By Pratik-->
                                        <!-- Ticket start:#94673 iOS-FR-Colour on pay screen.by rupesh -->
                                        <ContentView HeightRequest="80" HorizontalOptions="FillAndExpand" BackgroundColor="{Binding BackgroundColor}">
                                                <ContentView.GestureRecognizers>
                                                    <TapGestureRecognizer NumberOfTapsRequired="1" Command="{Binding Source={RelativeSource AncestorType={x:Type vm:PaymentViewModel}}, Path=selectPaymentHandle_Command, x:DataType=vm:PaymentViewModel}" CommandParameter="{Binding .}"/>
                                                </ContentView.GestureRecognizers>
                                                <ContentView.Triggers>
                                                    <DataTrigger TargetType="ContentView" Binding="{Binding DisplayName}" Value="[MOTO]">
                                                        <Setter Property="BackgroundColor" Value="Transparent" />
                                                    </DataTrigger>
                                                </ContentView.Triggers>
                                            <Border Stroke="{Binding BorderColor}">
                                                <StackLayout VerticalOptions="Center" Spacing="2" Padding="5,0">
                                                    <Label Text="{Binding DisplayName}"
                                                            TextColor="{Binding TextColor}"
                                                           x:Name="PaymentButton" IsEnabled="{Binding IsEnable}" Style="{x:Static resources:Styles.PaymentTypeLblStyle}"
                                                            HorizontalOptions="FillAndExpand">
                                                        <Label.Triggers>
                                                            <!-- <DataTrigger TargetType="Label" Binding="{Binding PaymentOptionType}" Value="5">
                                                                <Setter Property="TextColor" Value="{Binding Source={x:Reference PaymentButton}, Path=TextColor}" />
                                                            </DataTrigger>

                                                             <DataTrigger TargetType="Label" Binding="{Binding PaymentOptionType}" Value="6">
                                                                <Setter Property="TextColor" Value="{Binding Source={x:Reference PaymentButton}, Path=TextColor}" />
                                                            </DataTrigger>
 -->
                                                            <DataTrigger TargetType="Label" Binding="{Binding DisplayName}" Value="[MOTO]">
                                                                <Setter Property="TextColor" Value="Blue" />
                                                            </DataTrigger>
                                                            <DataTrigger TargetType="Label" Binding="{Binding PaymentOptionName}" Value="Afterpay">
                                                                <Setter Property="Text" Value="Afterpay" />
                                                            </DataTrigger>
                                                        </Label.Triggers>
                                                    </Label>
                                                    <Label Text="{Binding DisplaySubName}" IsVisible="{Binding DisplaySubName,Converter={Helpers:NullValueBoolConverter}}"
                                                            TextColor="{Binding TextColor}"
                                                            IsEnabled="{Binding IsEnable}"
                                                            Style="{x:Static resources:Styles.PaymentTypeLblStyle}"
                                                            FontSize="16" HorizontalOptions="FillAndExpand" />
                                                </StackLayout>
                                                </Border>
                                            </ContentView>
                                        <!-- Ticket end:#94673.by rupesh -->
                                        <!--End ticket #73190 By Pratik-->
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
