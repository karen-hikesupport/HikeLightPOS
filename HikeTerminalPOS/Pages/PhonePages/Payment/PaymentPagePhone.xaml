                        <StackLayout Grid.Row="4" IsVisible="{Binding IsPayment_PartialyPaid}" Margin="-100,0,-100,40" Spacing="0" Padding="0">
                            <BoxView BackgroundColor="{x:Static resources:AppColors.BordersColor}" HeightRequest="1" VerticalOptions="Start"/>
                            <Border BackgroundColor="White"  Stroke="{x:Static resources:AppColors.LightBordersColor}" Margin="30" Padding="7,0,7,0" HorizontalOptions="CenterAndExpand" HeightRequest="60" VerticalOptions="Center" >
                                <StackLayout Margin="10,10,10,10" Spacing="0" VerticalOptions="CenterAndExpand">
                                    <Label Text="{Localize:Translate SavePartialyPaidText}" Margin="20,0,20,0" Style="{x:Static resources:Styles.PaymentPartialyPaidHeaderLabelStyle}" />
                                    <Label Text="{Binding Invoice.TotalPay, StringFormat='Remaining: {0:c}' }" Style="{x:Static resources:Styles.PaymentPartialyPaidValueLabelStyle}" />
                                    <StackLayout.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding ParkCommand}" />
                                    </StackLayout.GestureRecognizers>
                                </StackLayout>
                            </Border>
                        </StackLayout>
                           <!--#29903 Void payment during checkout.-->
