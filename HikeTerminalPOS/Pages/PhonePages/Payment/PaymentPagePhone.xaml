                            <Border Style="{x:Static resources:Styles.FormRoundBorderStyle}" Padding="0" HeightRequest="60" StrokeThickness="0">
                            <userControls:CustomEntry x:Name="StrTenderAmountEntry" Text="{Binding Invoice.StrTenderAmount}" IsEnabled="{Binding IsStrTenderAmountEntryEnabled}" OnlyAllowDecimalValue="true"  Placeholder="Tendered amount" Style="{x:Static resources:Styles.PaymentTenderedAmountEntryStyle}">
