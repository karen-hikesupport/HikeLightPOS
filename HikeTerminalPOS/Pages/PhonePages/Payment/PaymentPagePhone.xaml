                                    HorizontalTextAlignment="Center"
                                    Text="{Binding Invoice.StrBackorderDeposite}"
                                    OnlyAllowDecimalValue="true"
                                    Placeholder="Backorder deposit amount"
                                    FontSize="20">
                                <userControls:CustomEntry.Behaviors>
                                    <toolkit:EventToCommandBehavior  EventName="TextChanged"
                                            Command="{Binding BackorderDepositHandleCommand}"
                                            CommandParameter="{x:Reference BackorderDepositEntry}"/>
                                </userControls:CustomEntry.Behaviors>
                            </userControls:CustomEntry>
                        </StackLayout>
                        <StackLayout  Grid.Row="1" VerticalOptions="CenterAndExpand" Spacing="10" Margin="10,0,10,0" >
