<?xml version="1.0" encoding="UTF-8"?>
<local:BaseContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="HikePOS.EnterSalePage"
    xmlns:local="clr-namespace:HikePOS"
    xmlns:resources="clr-namespace:HikePOS.Resources"
    xmlns:Localize="clr-namespace:HikePOS;assembly=HikePOS"
    xmlns:userControls="clr-namespace:HikePOS.UserControls"
    xmlns:model="clr-namespace:HikePOS.Models"
    xmlns:Helpers="clr-namespace:HikePOS.Helpers"
    xmlns:vm="clr-namespace:HikePOS.ViewModels"
    x:TypeArguments="vm:EnterSaleViewModel"
    x:DataType="vm:EnterSaleViewModel"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    NavigationPage.HasNavigationBar="False"
    x:Name="entersalepage"
    Title="{Localize:Translate EnterSale_TitleText}">
    <!--<ContentPage.ToolbarItems>
        <ToolbarItem IconImageSource="ic_search" Command="{Binding SearchProductCommand}" AutomationId="searchButton" />
    </ContentPage.ToolbarItems>-->
    <ContentPage.Resources>
        <ResourceDictionary>
            <local:EnterSaleItemTemplateSelector x:Key="ItemTemplateSelector"/>
        </ResourceDictionary>
    </ContentPage.Resources>
    <ContentPage.Content>
        <Grid>
            <Grid VerticalOptions="FillAndExpand"
                  RowSpacing="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="{OnPlatform iOS='44', Android='48'}"/>
                    <RowDefinition Height="2"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <!-- Start ticket #60456 Pratik -->
                <ContentView x:Name="PrintReceiptSummaryView"
                             Scale="0"
                             Grid.RowSpan="3"
                             Grid.Row="0"
                             HorizontalOptions="Start"
                             IsVisible="True"/>
                <!-- End ticket #60456 Pratik -->
                <Grid Grid.Row="0"
                      VerticalOptions="FillAndExpand"
                      ColumnDefinitions="70,*,250">
                    <ImageButton Source="ic_hamburger"
                                 Grid.Column="0"
                                 Grid.Row="0"
                                 MinimumHeightRequest="32"
                                 MinimumWidthRequest="32"
                                 WidthRequest="32"
                                 HeightRequest="32"
                                 Command="{Binding SliderMenuHandleClickedCommand}"
                                 BackgroundColor="Transparent"
                                 HorizontalOptions="Start"
                                 Margin="20,0,0,0"/>
                    <Label Text="{Localize:Translate EnterSale_TitleText}"
                           Grid.Column="1"
                           Grid.Row="0"
                           Style="{x:Static resources:Styles.PageTitleLabelStyle}"
                           VerticalOptions="Center"
                           HorizontalTextAlignment="Center"
                           Margin="150,0,0,0"/>
                    <HorizontalStackLayout Spacing="20"
                                           Grid.Column="2"
                                           Grid.Row="0"
                                           HorizontalOptions="End">
                        <!--#94565-->
                        <Grid VerticalOptions="Center" IsVisible="{Binding invoicemodel.IsTabelVisible}" HeightRequest="45" WidthRequest="68" Padding="0,2,0,4">
                                <Image Source="table_layout"
                                    HeightRequest="40"
                                    WidthRequest="50" VerticalOptions="Center" HorizontalOptions="End" Margin="0,0,15,0">
                                    <Image.Triggers>
                                        <DataTrigger TargetType="Image"  Binding="{Binding invoicemodel.IsRestaurantPOS}" Value="False">
                                            <Setter Property="Source" Value="table_layout_disable"/>
                                        </DataTrigger>
                                    </Image.Triggers>
                                </Image>
                                <Border StrokeShape="RoundRectangle 13" VerticalOptions="Start"
                                        BackgroundColor="#26394b"
                                        Grid.Column="0" Grid.Row="0"
                                        HeightRequest="26"
                                        WidthRequest="26" HorizontalOptions="End">
                                    <Label Text="{Binding OccupiedTable}" FontFamily="HikeDefaultFont"                                        
                                        VerticalTextAlignment="Center"
                                        HorizontalOptions="Center" FontSize="12"
                                        TextColor="White"/>
                                    <Border.Triggers>
                                        <DataTrigger TargetType="Border"
                                                        Binding="{Binding OccupiedTable}"
                                                        Value="0">
                                            <Setter Property="IsVisible"
                                                    Value="False"/>
                                        </DataTrigger>
                                    </Border.Triggers>
                                </Border>
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding FloorCommand}"/>
                            </Grid.GestureRecognizers>
                        </Grid>
                        <!-- <Button Command="{Binding FloorCommand}"
                                Text="Tables"
                               
                                Style="{x:Static resources:Styles.PaymentTypeButtonStyle}"
                                BorderWidth="1"
                                BorderColor="Transparent"
                                HorizontalOptions="Fill"
                                BackgroundColor="Transparent"
                                TextColor="{x:Static resources:AppColors.HikeColor}"
                                HeightRequest="40"
                                FontSize="18">
                        </Button> -->
                        <!--#94565-->
                        <ImageButton Source="ic_search"
                                     MinimumHeightRequest="36"
                                     MinimumWidthRequest="36"
                                     WidthRequest="36"
                                     HeightRequest="36"
                                     Command="{Binding SearchProductCommand}"
                                     BackgroundColor="Transparent"
                                     HorizontalOptions="End"
                                     Padding="3,3,0,3"/>
                        <ImageButton Source="scanicon"
                                     MinimumHeightRequest="34"
                                     MinimumWidthRequest="36"
                                     WidthRequest="40"
                                     HeightRequest="34"
                                     HorizontalOptions="End"
                                     BackgroundColor="Transparent"
                                     Command="{Binding BarcodeScanSelectedCommand}"
                                     Padding="3,3,0,3"
                                     Margin="0,0,20,0"/>
                    </HorizontalStackLayout>
                </Grid>
                <BoxView Grid.Row="1"
                         VerticalOptions="FillAndExpand"
                         HorizontalOptions="FillAndExpand"
                         Color="{x:Static resources:AppColors.HeaderSepratorColor}"/>
                <Grid x:Name="MainGrid"
                      Grid.Row="2"
                      VerticalOptions="FillAndExpand"
                      BackgroundColor="{Binding MainGridBackgroundColor}"
                      RowSpacing="0"
                      ColumnSpacing="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="65*"/>
                        <ColumnDefinition Width="0.4"/>
                        <ColumnDefinition Width="35*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="101"/>
                        <RowDefinition Height="0.7"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!--#38783 iPad: Feature request - Register's Name in Process Sale-->
                    <Grid x:Name="innerGrid"
                          Grid.Row="0"
                          Grid.Column="0">
                        <StackLayout VerticalOptions="Start"
                                     HeightRequest="43"
                                     Orientation="Vertical">
                            <Grid  Margin="20,5,0,0"
                                   HorizontalOptions="FillAndExpand"
                                   VerticalOptions="Center"
                                   HeightRequest="42"
                                   Grid.Row="0"
                                   Grid.Column="0"
                                   ColumnSpacing="10"
                                   ColumnDefinitions="*,60">
                                <HorizontalStackLayout Grid.Column="0"
                                                       Spacing="5">
                                    <Label FontSize="Small"
                                           VerticalTextAlignment="Center"
                                           Text="{Binding OutletName}"/>
                                    <Label FontSize="Small"
                                           VerticalTextAlignment="Center"
                                           Margin="-2,0,0,0"
                                           Text=">>"
                                           CharacterSpacing="0"/>
                                    <Label FontSize="Small"
                                           VerticalTextAlignment="Center"
                                           Margin="-2,0,0,0"
                                           Text="{Binding RegisterName}"
                                           TextColor="{x:Static resources:AppColors.LinkTitleColor}">
                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label"
                                                         Binding="{Binding IsMultipleRegister}"
                                                         Value="False">
                                                <Setter Property="TextColor"
                                                        Value="Black"/>
                                            </DataTrigger>
                                        </Label.Triggers>
                                        <Label.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding RegisterLblCommand}"/>
                                        </Label.GestureRecognizers>
                                    </Label>
                                    <Label FontSize="Small"
                                           VerticalTextAlignment="Center"
                                           Margin="-2,0,0,0"
                                           Text="{Binding BatchNumber}"
                                           CharacterSpacing="0"/>

                                    <!--#94565-->
                                    <HorizontalStackLayout VerticalOptions="Center"
                                                           Margin="20,0,0,0"
                                                           Spacing="6"
                                                           IsVisible="{Binding invoicemodel.IsTableSelect}">
                                        <Image Source="table"
                                               HeightRequest="24"
                                               WidthRequest="24"/>
                                        <Label Grid.Column="1"
                                               FontSize="14" TextColor="Black"
                                               VerticalTextAlignment="Center" FontFamily="{x:Static resources:Fonts.HikeDefaultFont}"
                                               Text="{Binding invoicemodel.Table.Name}"/>
                                    </HorizontalStackLayout>
                                    <!--#94565-->

                                </HorizontalStackLayout>
                                <ImageButton Grid.Column="1"
                                             Source="icon_setting"
                                             Padding="10,8"
                                             Margin="0,0,5,0"
                                             IsEnabled="{Binding IsHavingSortingEnabled}"
                                             Command="{Binding SortingFilterMenuOpenCommand}"
                                             WidthRequest="{OnPlatform Default='30', Android='25'}"
                                             HeightRequest="{OnPlatform Default='30', Android='25'}"
                                             HorizontalOptions="EndAndExpand"></ImageButton>
                            </Grid>
                            <BoxView HeightRequest="0.5"
                                     Color="LightGray"/>
                        </StackLayout>

                        <CollectionView x:Name="BottomMenuListView"
                                        HeightRequest="56"
                                        Margin="20,43,0,0"
                                        SelectionMode="None"
                                        VerticalOptions="FillAndExpand"
                                        ItemSizingStrategy="MeasureAllItems"
                                        ItemsSource="{Binding Categories}">
                            <!-- Ticket start:#92957 Couldn't scroll product type on POS page.by rupesh -->
                            <CollectionView.ItemsLayout>
                                <LinearItemsLayout Orientation="Horizontal"
                                                   ItemSpacing="0"/>
                            </CollectionView.ItemsLayout>
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="model:CategoryDto">
                                    <Grid Margin="0,0,30,0">
                                    <!--<Grid HeightRequest="56" Margin="0,0,30,0" ColumnDefinitions="Auto,Auto" ColumnSpacing="5">-->
                                        <Label Grid.Column="0" Text="{Binding Name}"
                                               Style="{x:Static resources:Styles.CategoryTitleLabelStyle}"
                                               TextColor="{Binding IsSelected, Converter={Helpers:ActiveDeactiveColorConverter}}"
                                               LineBreakMode="NoWrap"
                                               HeightRequest="50"
                                               VerticalTextAlignment="Center"
                                               Padding="0,8,0,0"
                                               HorizontalOptions="Start">
                                            <Label.GestureRecognizers>
                                                <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:EnterSaleViewModel}}, Path=CategoryTappedCommand, x:DataType=vm:EnterSaleViewModel}"
                                                                      CommandParameter="{Binding .}"/>
                                            </Label.GestureRecognizers>
                                        </Label>
                                        <!-- <ActivityIndicator Grid.Column="1" IsVisible="{Binding IsLoad}" Margin="0,8,0,0"
                                             HeightRequest="15" WidthRequest="15" IsRunning="{Binding IsLoad}" VerticalOptions="Center" 
                                             Color="{x:Static resources:AppColors.HikeColor}"/> -->
                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                            <!-- Ticket end:#92957.by rupesh -->
                        </CollectionView>
                    </Grid>
                    <BoxView x:Name="lineview"
                             Grid.Row="1"
                             Grid.Column="0"
                             Color="{x:Static resources:AppColors.LightBordersColor}"
                             HeightRequest="0.7"/>
                    <!--<local:CustomCollectionView x:Name="lstViewProductList"
                                        Grid.Row="2" Grid.Column="0"
                                        Margin="17,25,17,25"
                                        ColumnSpacing="10"
                                        RowSpacing="10"
                                        NoOfColumn="5"
                                        ItemTemplateSelector ="{StaticResource ItemTemplateSelector}"
                                        ItemSelected="SelectItemHandle_ItemTapped"
                                        ItemsSource="{Binding EnterSaleItems}" />-->
                    <!--Start #90945 iOS:FR Hot keys: POS Process Sale Window By Pratik-->
                    <Grid  Grid.Row="2"
                           Grid.Column="0"
                           Margin="17,25,17,25">
                        <Grid.Triggers>
                            <DataTrigger TargetType="Grid"
                                         Binding="{Binding DisplayFolder}"
                                         Value="True">
                                <Setter Property="BackgroundColor"
                                        Value="{Binding LayoutColor, Converter={Helpers:ColorTypeToColorConverter},ConverterParameter='bg'}"/>
                            </DataTrigger>
                            <DataTrigger TargetType="Grid"
                                         Binding="{Binding DisplayFolder}"
                                         Value="False">
                                <Setter Property="BackgroundColor"
                                        Value="Transparent "/>
                            </DataTrigger>
                        </Grid.Triggers>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border IsVisible="{Binding DisplayFolder}"
                             BackgroundColor="{Binding LayoutColor, Converter={Helpers:ColorTypeToColorConverter}}" HeightRequest="60">
                             <Grid>
                                <Label Text="{Binding SelectedCategoryName}" FontSize="20" TextColor="{Binding LayoutColor, Converter={Helpers:ColorTypeToColorConverter},ConverterParameter='text'}"
                                     FontFamily="{x:Static resources:Fonts.HikeLightFont}" Margin="20,0,40,0" VerticalTextAlignment="Center"/>
                                <!-- Ticket start: #95015.by rupesh -->
                                <Button Text="{Localize:Translate CloseIconUnicode}"
                                        Style="{x:Static resources:Styles.EntersaleSearchCustomerButtonStyle}"
                                        TextColor="{Binding LayoutColor, Converter={Helpers:ColorTypeToColorConverter},ConverterParameter='text'}"
                                        HorizontalOptions="End" MinimumHeightRequest="30" 
                                    MinimumWidthRequest="30" WidthRequest="30" Padding="{OnPlatform Default='10,3,0,3', Android='2,3,0,3'}"  
                                    HeightRequest="30" Command="{Binding CloseCategoryTappedCommand}" 
                                    BackgroundColor="Transparent" Margin="0,0,20,0" VerticalOptions="Center"/>
                                <!-- Ticket end: #95015.by rupesh -->
                            </Grid>
                        </Border>
                        <CollectionView x:Name="lstViewProductList"
                                        Grid.Row="1"
                                        SelectionMode="None"
                                        VerticalOptions="FillAndExpand"
                                        ItemSizingStrategy="MeasureFirstItem"
                                        RemainingItemsThreshold="1"
                                        RemainingItemsThresholdReachedCommand="{Binding RemainingProductCommand}"
                                        ItemTemplate="{StaticResource ItemTemplateSelector}"
                                        ItemsSource="{Binding EnterSaleItems}">
                            <CollectionView.ItemsLayout>
                                <GridItemsLayout Orientation="Vertical"
                                                 Span="5"
                                                 VerticalItemSpacing="0"
                                                 HorizontalItemSpacing="0"/>
                            </CollectionView.ItemsLayout>
                        </CollectionView>
                    </Grid>
                    <!--End #90945 By Pratik-->
                    <BoxView Grid.Row="0"
                             Grid.Column="1"
                             Grid.RowSpan="3"
                             Color="{x:Static resources:AppColors.LightBordersColor}"
                             WidthRequest="0.4"/>
                    <Grid Grid.Row="0"
                          Grid.Column="2"
                          Grid.RowSpan="3"
                          RowSpacing="0"
                          VerticalOptions="FillAndExpand">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <!-- Ticket start:#92764 iOS:FR Need to manage display product stock.by rupesh -->
                        <!--Ticket start:#22406 Quote sale.by rupesh-->
                        <Grid Grid.Row="0"
                              RowSpacing="0"
                              ColumnSpacing="0"
                              BackgroundColor="White"
                              IsVisible="{Binding IsQuoteOrBackorderDisplay}">
                            <Grid.Triggers>
                                <DataTrigger TargetType="Grid"
                                             Binding="{Binding IsQuoteDisplay}"
                                             Value="False">
                                    <Setter Property="Grid.ColumnDefinitions"
                                            Value="*,0,0,0.5,*"/>
                                </DataTrigger>
                                <DataTrigger TargetType="Grid"
                                             Binding="{Binding IsBackorderDisplay}"
                                             Value="False">
                                    <Setter Property="Grid.ColumnDefinitions"
                                            Value="*,0.5,*,0,0"/>
                                </DataTrigger>
                            </Grid.Triggers>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="50"/>
                                <RowDefinition Height="0.5"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="0.5"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="0.5"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button x:Name="ProcessSaleBtn"
                                    Grid.Row="0"
                                    Grid.Column="0"
                                    Margin="5"
                                    BorderWidth="0"
                                    Text="{Localize:Translate EnterSale_TitleText}"
                                    TextColor="{x:Static resources:AppColors.PrimaryTextColor}"
                                    Command="{Binding ProcessSaleSelectedCommand}"
                                    CommandParameter="{Binding .}"/>

                            <BoxView Grid.Row="0"
                                     Grid.Column="0"
                                     HorizontalOptions="FillAndExpand"
                                     HeightRequest="2"
                                     Color="{Binding ProcessSaleColor}"
                                     VerticalOptions="End"/>
                            <!--Start ticket #76209 iOS:FR: User Permission : Add a permission for allowing 'Issue a Quote' By Pratik-->
                            <BoxView IsVisible="{Binding IsQuoteDisplay}"
                                     Grid.Row="0"
                                     Grid.Column="1"
                                     Color="{x:Static resources:AppColors.LightBordersColor}"/>
                            <!--Ticket start:#84289 IOS-Feature:-Ability to re-open Backorders and apply partial payments at any time. by rupesh-->
                            <Button IsVisible="{Binding IsQuoteDisplay}"
                                    x:Name="QuoteBtn"
                                    Grid.Row="0"
                                    Grid.Column="2"
                                    Margin="5"
                                    Text="Quote"
                                    IsEnabled="True"
                                    Command="{Binding QuoteSelectedCommand}"
                                    CommandParameter="{Binding .}"
                                    TextColor="{x:Static resources:AppColors.PrimaryTextColor}">
                                <Button.Triggers>
                                    <DataTrigger TargetType="Button"
                                                 Binding="{Binding invoicemodel.Invoice.Status}"
                                                 Value="6">
                                        <Setter Property="IsEnabled"
                                                Value="False"/>
                                    </DataTrigger>
                                </Button.Triggers>
                            </Button>
                            <!--Ticket end:#84289. by rupesh-->
                            <BoxView IsVisible="{Binding IsQuoteDisplay}"
                                     Grid.Row="0"
                                     Grid.Column="2"
                                     HorizontalOptions="FillAndExpand"
                                     HeightRequest="2"
                                     Color="{Binding QuoteBtnColor}"
                                     VerticalOptions="End"/>

                            <BoxView IsVisible="{Binding IsBackorderDisplay}"
                                     Grid.Row="0"
                                     Grid.Column="3"
                                     Color="{x:Static resources:AppColors.LightBordersColor}"/>
                            <Button IsVisible="{Binding IsBackorderDisplay}"
                                    x:Name="BackorderBtn"
                                    Grid.Row="0"
                                    Grid.Column="4"
                                    Margin="5"
                                    Text="Backorder"
                                    IsEnabled="True"
                                    Command="{Binding BackorderSelectedCommand}"
                                    CommandParameter="{Binding .}"
                                    TextColor="{x:Static resources:AppColors.PrimaryTextColor}">
                                <Button.Triggers>
                                    <DataTrigger TargetType="Button"
                                                 Binding="{Binding invoicemodel.Invoice.Status}"
                                                 Value="6">
                                        <Setter Property="IsEnabled"
                                                Value="False"/>
                                    </DataTrigger>
                                </Button.Triggers>
                            </Button>
                            <BoxView IsVisible="{Binding IsBackorderDisplay}"
                                     Grid.Row="0"
                                     Grid.Column="4"
                                     HorizontalOptions="FillAndExpand"
                                     HeightRequest="2"
                                     Color="{Binding BackorderBtnColor}"
                                     VerticalOptions="End"/>
                            <!--End ticket #76209 By Pratik-->
                            <BoxView Grid.Row="1"
                                     Grid.Column="0"
                                     Grid.ColumnSpan="6"
                                     HeightRequest="0.5"
                                     Color="{x:Static resources:AppColors.LightBordersColor}"/>
                        </Grid>
                        <!--Ticket end:#22406 Quote sale.by rupesh-->
                        <!-- Ticket end:#92764.by rupesh -->
                        <Grid x:Name="LineItemGrid"
                              Grid.Row="1"
                              RowSpacing="1"
                              BackgroundColor="White"
                              VerticalOptions="FillAndExpand">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="50"/>
                                <RowDefinition Height="0.5"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="0.5"/>
                                <RowDefinition Height="{Binding invoicemodel.Invoice.StatusHeight}"/>
                                <RowDefinition Height="{Binding ExpandHeight}"/>
                                <RowDefinition Height="0.5"/>
                                <RowDefinition Height="55"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid Grid.Row="0"
                                  Grid.Column="0"
                                  Grid.ColumnSpan="2"
                                  RowSpacing="0"
                                  ColumnSpacing="0"
                                  BackgroundColor="White">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="50"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="30"/>
                                    <ColumnDefinition Width="30"/>
                                    <ColumnDefinition Width="30"/>
                                    <ColumnDefinition Width="0.5"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <Grid Grid.Row="0"
                                      Grid.Column="0"
                                      RowSpacing="0"
                                      ColumnSpacing="0"
                                      Margin="5,0,0,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="50"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Image Source="customer.png"
                                           Grid.Row="0"
                                           Grid.Column="0"
                                           HeightRequest="25"
                                           WidthRequest="25"
                                           Aspect="AspectFit"
                                           VerticalOptions="Center"
                                           HorizontalOptions="Center"/>
                                    <StackLayout Grid.Row="0"
                                                 Grid.Column="1"
                                                 Spacing="0"
                                                 VerticalOptions="CenterAndExpand">
                                        <Grid Style="{x:Static resources:Styles.CustomerNameGridStyle}">
                                            <Label x:Name="selectCustomelbl"
                                                   Text="{Localize:Translate SelectCustomerText}"
                                                   VerticalTextAlignment="Center"
                                                   Style="{x:Static resources:Styles.CustomerNameLabelStyle}"
                                                   HeightRequest="50">
                                                <Label.Triggers>
                                                    <DataTrigger TargetType="Label"
                                                                 Binding="{Binding invoicemodel.Invoice.CustomerName, Converter={Helpers:NullValueBoolConverter}}"
                                                                 Value="True">
                                                        <Setter Property="IsVisible"
                                                                Value="False"/>
                                                    </DataTrigger>
                                                </Label.Triggers>
                                            </Label>
                                            <VerticalStackLayout VerticalOptions="Center">
                                                <VerticalStackLayout.Triggers>
                                                    <DataTrigger TargetType="VerticalStackLayout"
                                                                 Binding="{Binding Source={x:Reference selectCustomelbl}, Path=IsVisible}"
                                                                 Value="True">
                                                        <Setter Property="IsVisible"
                                                                Value="False"/>
                                                    </DataTrigger>
                                                </VerticalStackLayout.Triggers>
                                                <Label x:Name="customernamelbl"
                                                       Text="{Binding invoicemodel.Invoice.CustomerName}"
                                                       Style="{x:Static resources:Styles.CustomerNameLabelStyle}"
                                                       BackgroundColor="White"/>
                                                <Label IsVisible="{Binding invoicemodel.Invoice.CustomerGroupDiscountNote,Converter={Helpers:NullValueBoolConverter}}"
                                                       Text="{Binding invoicemodel.Invoice.CustomerGroupDiscountNote}"
                                                       Style="{x:Static resources:Styles.CustomerGroupNameLabelStyle}"
                                                       VerticalOptions="End"/>
                                            </VerticalStackLayout>
                                        </Grid>
                                    </StackLayout>
                                    <Grid.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding invoicemodel.CustomerModel.OpenSearchCustomerCommand}"
                                                              CommandParameter="{Binding invoicemodel.Invoice.CustomerDetail}"/>
                                    </Grid.GestureRecognizers>
                                </Grid>
                                <!--//Ticket start:#26664 IOS - New feature :: Customer delivery address.by rupesh-->
                                <Button x:Name="btnDeliveryCustomer"
                                        IsVisible="{Binding DeliveryCustomerVisible}"
                                        Grid.Row="0"
                                        Grid.Column="1"
                                        WidthRequest="30"
                                        HeightRequest="30"
                                        TextColor="Black"
                                        VerticalOptions="CenterAndExpand"
                                        Text="{Localize:Translate TruckIconUnicode}"
                                        Style="{x:Static resources:Styles.EntersaleSearchCustomerButtonStyle}"
                                        BackgroundColor="Transparent"
                                        Command="{Binding invoicemodel.CustomerModel.DeliveryCustomerCommand}"
                                        CommandParameter="{Binding invoicemodel.Invoice.CustomerDetail}">
                                    <Button.Triggers>
                                        <DataTrigger TargetType="Button"
                                                     Binding="{Binding invoicemodel.Invoice.DeliveryAddressId, Converter={Helpers:NullValueBoolConverter}}"
                                                     Value="True">
                                            <Setter Property="TextColor"
                                                    Value="{x:Static resources:AppColors.HikeColor}"/>
                                        </DataTrigger>
                                    </Button.Triggers>
                                </Button>
                                <!--//Ticket end:#26664 .by rupesh-->
                                <Button x:Name="btnEditCustomer"
                                        Grid.Row="0"
                                        Grid.Column="2"
                                        IsVisible="{Binding EditCustomerVisible}"
                                        WidthRequest="30"
                                        HeightRequest="30"
                                        TextColor="Black"
                                        VerticalOptions="CenterAndExpand"
                                        Text="{Localize:Translate EditIconUnicode}"
                                        Style="{x:Static resources:Styles.EntersaleSearchCustomerButtonStyle}"
                                        BackgroundColor="Transparent"
                                        Command="{Binding invoicemodel.CustomerModel.EditCustomerCommand}"
                                        CommandParameter="{Binding invoicemodel.Invoice.CustomerDetail}"/>
                                <Button x:Name="btnRemoveCustomer"
                                        Grid.Row="0"
                                        Grid.Column="3"
                                        IsVisible="{Binding RemoveCustomerVisible}"
                                        WidthRequest="30"
                                        TextColor="Black"
                                        VerticalOptions="CenterAndExpand"
                                        Text="{Localize:Translate CloseIconUnicode}"
                                        Style="{x:Static resources:Styles.EntersaleSearchCustomerButtonStyle}"
                                        BackgroundColor="Transparent"
                                        Command="{Binding invoicemodel.CustomerModel.RemoveCustomerCommand}"
                                        CommandParameter="{Binding invoicemodel.Invoice.CustomerDetail}"/>
                                <BoxView Color="{x:Static resources:AppColors.LightBordersColor}"
                                         Grid.Row="0"
                                         Grid.Column="4"
                                         WidthRequest="0.5"/>
                                <Button Text="••••"
                                        Grid.Row="0"
                                        Grid.Column="5"
                                        HeightRequest="50"
                                        WidthRequest="50"
                                        TextColor="{x:Static resources:AppColors.NavigationBarBackgroundColor}"
                                        Command="{Binding MoreOptionCommand}"
                                        BackgroundColor="Transparent"/>
                            </Grid>
                            <BoxView Grid.Row="1"
                                     Grid.Column="0"
                                     Grid.ColumnSpan="2"
                                     Color="{x:Static resources:AppColors.LightBordersColor}"
                                     HeightRequest="0.5"/>
                            <OnPlatform x:TypeArguments="View">
                                <On Platform="Android">
                                    <CollectionView Grid.Row="2"
                                                    Grid.Column="0"
