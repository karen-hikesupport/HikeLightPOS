<?xml version="1.0" encoding="UTF-8"?>
<local:PopupBasePage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="HikePOS.AgeVerificationPopupPage"
    xmlns:local="clr-namespace:HikePOS"
    xmlns:resources="clr-namespace:HikePOS.Resources"
    xmlns:Localize="clr-namespace:HikePOS;assembly=HikePOS"
    xmlns:userControls="clr-namespace:HikePOS.UserControls"
    xmlns:system="clr-namespace:System;assembly=mscorlib"
    xmlns:vm="clr-namespace:HikePOS.ViewModels"
    x:TypeArguments="vm:BaseViewModel"
    ShowDirection="TopToBottom"
    Title="Title"
    x:Name="PopupPage"
    BackgroundColor="{StaticResource PopupBG}">
    <ContentPage.Content>
        <ScrollView VerticalOptions="Center"
                    HorizontalOptions="Center">
            <!-- Start ticket #60456 Pratik -->
            <Grid RowSpacing="5"
                  ColumnSpacing="10"
                  Padding="10"
                  VerticalOptions="Center"
                  HorizontalOptions="Center"
                  BackgroundColor="White">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="{OnIdiom Phone='120',Default='150'}"/>
                    <ColumnDefinition Width="{OnIdiom Phone='120',Default='150'}"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="40"/>
                    <RowDefinition Height="80"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="1"/>
                    <RowDefinition Height="40"/>
                    <RowDefinition Height="1"/>
                    <RowDefinition Height="40"/>
                    <RowDefinition Height="40"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="50"/>
                </Grid.RowDefinitions>
                <Label Grid.Row="0"
                       Grid.Column="0"
                       Grid.ColumnSpan="2"
                       Text="Upload eligibility proof"
                       FontSize="18"
                       FontFamily="{x:Static resources:Fonts.HikeBoldFont}"
                       TextColor="{x:Static resources:AppColors.PrimaryTextColor}"
                       VerticalTextAlignment="Center"
                       HorizontalTextAlignment="Center"
                       HorizontalOptions="Center"
                       VerticalOptions="Start"
                       Margin="10"/>
                <Border Grid.Row="1"
                        Grid.Column="0"
                        Grid.ColumnSpan="2"
                        StrokeThickness="1"
                        StrokeDashArray="5,3"
                        Stroke="Gray">
                    <VerticalStackLayout
                        Margin="0,10,0,10"
                        Spacing="10"
                        HeightRequest="78"
                        VerticalOptions="Center"
                        Padding="0,10">
                        <Label
                            Text="Choose Image File"
                            FontSize="16"
                            FontFamily="{x:Static resources:Fonts.HikeLightFont}"
                            TextColor="{x:Static resources:AppColors.PrimaryTextColor}"
                            VerticalTextAlignment="Center"
                            HorizontalTextAlignment="Center"
                            HorizontalOptions="Center"
                            VerticalOptions="Center"/>
                        <Label Text="You can select a JPG/JPEG/PNG file with&#10; a maximum 5MB size."
                               FontSize="12"
                               FontFamily="{x:Static resources:Fonts.HikeLightFont}"
                               TextColor="{x:Static resources:AppColors.PrimaryTextColor}"
                               VerticalTextAlignment="Center"
                               HorizontalTextAlignment="Center"
                               HorizontalOptions="Center"/>
                               <VerticalStackLayout.GestureRecognizers>
                                   <TapGestureRecognizer Tapped="ChooseImage_Clicked"/>
                               </VerticalStackLayout.GestureRecognizers>
                    </VerticalStackLayout>
                </Border>
                <VerticalStackLayout x:Name="ImagePreview"
                                     Margin="0,8,0,0"
                                     IsVisible="False"
                                     Grid.Row="2"
                                     Grid.Column="0"
                                     Grid.ColumnSpan="2"
                                     WidthRequest="100"
                                     HeightRequest="115">
                    <Image x:Name="Image" Aspect="Fill"
                           WidthRequest="80"
                           HeightRequest="80"/>
                    <Button Clicked="CancelImage_Clicked" BorderWidth="0" FontAttributes="Bold"
                            Text="REMOVE" HorizontalOptions="Center" MinimumHeightRequest="35" HeightRequest="35"
                            TextColor="{x:Static resources:AppColors.RedButtonBackgroundColor}"/>
                </VerticalStackLayout>
                <Label x:Name="SizeErrorLabel"
                       IsVisible="False"
                       Grid.Row="3"
                       Grid.ColumnSpan="2"
                       Text="The uploaded image size exceeds 5MB limit. Please try another image"
                       FontSize="12"
                       FontFamily="{x:Static resources:Fonts.HikeLightFont}"
                       TextColor="{x:Static resources:AppColors.PrimaryTextColor}"
                       VerticalTextAlignment="Center"
                       HorizontalTextAlignment="Center"
                       HorizontalOptions="Center"/>
              
                <Grid Grid.Row="5" ColumnDefinitions="*,Auto,*"
                    Grid.ColumnSpan="2" ColumnSpacing="6">
                    <BoxView Grid.Row="6" HeightRequest="1"
                         Grid.Column="0" VerticalOptions="Center" 
                         Color="{x:Static resources:AppColors.LightBordersColor}"/>
                    <Label
                        Grid.Column="1"
                        Text="OR"
                        FontSize="16"
                        FontFamily="{x:Static resources:Fonts.HikeLightFont}"
                        TextColor="{x:Static resources:AppColors.PrimaryTextColor}"
                        VerticalTextAlignment="Center"
                        HorizontalTextAlignment="Center"
                        HorizontalOptions="Center"/>
                   <BoxView HeightRequest="1" 
                         Grid.Column="2" VerticalOptions="Center"
                         Color="{x:Static resources:AppColors.LightBordersColor}"/>
                </Grid>
               
                <Label Grid.Row="7"
                       Grid.Column="0"
                       Grid.ColumnSpan="2"
                       Text="Please enter the customer's date of birth to proceed"
                       FontSize="12"
                       FontFamily="{x:Static resources:Fonts.HikeBoldFont}"
                       TextColor="{x:Static resources:AppColors.PrimaryTextColor}"
                       VerticalTextAlignment="Center"
                       HorizontalTextAlignment="Center"
                       HorizontalOptions="Center"
                       VerticalOptions="Start"
                       Margin="10,5"/>
              <Border Grid.Row="8"
                Grid.ColumnSpan="2"
                Style="{x:Static resources:Styles.FormRoundBorderStyle}" HeightRequest="40"
                Padding="0">
                <userControls:CustomDatePicker DisplayBorder="False"
                                               FontFamily="{x:Static resources:Fonts.HikeDefaultFont}"
                                               TextColor="{x:Static resources:AppColors.PrimaryTextColor}"
                                               DateSelected="BirthDatePicker_DateSelected"
                                               Format="dd/MM/yyyy"
                                               FontSize="16"
                                               Style="{x:Static resources:Styles.DatePickerLabelStyle}"
                                               MaximumDate="{x:Static system:DateTime.Today}"
                                               HorizontalOptions="Center"/>
                </Border>
                <Label x:Name="AgeErrorLabel"
                       IsVisible="False"
                       Grid.Row="9"
                       Grid.ColumnSpan="2"
                       FontSize="12"
                       FontFamily="{x:Static resources:Fonts.HikeAwesomeFont}"
                       TextColor="{x:Static resources:AppColors.RedButtonBackgroundColor}"
                       VerticalTextAlignment="Center"
                       HorizontalOptions="Center"/>
                <Button x:Name="NoButton"
                        Text="Cancel"
                        Grid.Row="10"
                        Grid.Column="0"
                        HeightRequest="44"
                        BackgroundColor="White"
                        BorderColor="{x:Static resources:AppColors.RedButtonBackgroundColor}"
                        BorderWidth="1"
                        FontSize="18"
                        FontFamily="{x:Static resources:Fonts.HikeDefaultFont}"
                        CornerRadius="5"
                        TextColor="{x:Static resources:AppColors.RedButtonBackgroundColor}"
                        Clicked="CancelHandle_Clicked"
                        Margin="0,10,0,0"/>
                <Button x:Name="YesButton"
                        Text="Confirm"
                        Grid.Row="10"
                        Grid.Column="1"
                        HeightRequest="44"
                        BackgroundColor="White"
                        BorderColor="{x:Static resources:AppColors.HikeColor}"
                        BorderWidth="1"
                        FontSize="18"
                        FontFamily="{x:Static resources:Fonts.HikeDefaultFont}"
                        CornerRadius="5"
                        TextColor="{x:Static resources:AppColors.HikeColor}"
                        Clicked="SaveHandle_Clicked"
                        Margin="0,10,0,0"/>
            </Grid>
            <!-- End ticket #60456 Pratik -->
        </ScrollView>
    </ContentPage.Content>
</local:PopupBasePage>