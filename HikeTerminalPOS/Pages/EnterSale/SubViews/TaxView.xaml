<?xml version="1.0" encoding="UTF-8"?>
<Border xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
	   xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"  
		x:Class="HikePOS.TaxView" 
		xmlns:resources="clr-namespace:HikePOS.Resources" 
		xmlns:Localize="clr-namespace:HikePOS;assembly=HikePOS"
		xmlns:Helpers="clr-namespace:HikePOS.Helpers" 
		xmlns:userControls="clr-namespace:HikePOS.UserControls" 
		Padding="0"
		xmlns:vm="clr-namespace:HikePOS.ViewModels"
        x:DataType="vm:InvoiceViewModel" 
		xmlns:model="clr-namespace:HikePOS.Models"
        Stroke="{x:Static resources:AppColors.BordersColor}" 
		StrokeShape="RoundRectangle 5,5,5,5">
	<StackLayout Spacing="0" BackgroundColor="White">
		<Label Text="{Localize:Translate Tax_Codes}" HeightRequest="60" Style="{x:Static resources:Styles.DicountTipTitleLabelStyle}"/>
		<BoxView BackgroundColor="{x:Static resources:AppColors.BordersColor}" HeightRequest="1" />
		<CollectionView x:Name="InvoiceTaxList" ItemsSource="{Binding Invoice.Taxgroup}" HeightRequest="160" SelectionMode="None">
			<CollectionView.ItemTemplate>
				<DataTemplate x:DataType="model:LineItemTaxDto">
					<StackLayout Spacing ="0" HeightRequest="50">
						<StackLayout Orientation = "Horizontal" HeightRequest="49.5" Padding="10,0,10,0">
							<Label Text="{Binding TaxName}" FontSize="16" FontFamily="{x:Static resources:Fonts.HikeLightFont}" HorizontalOptions="StartAndExpand" VerticalTextAlignment="Center"/>
							<Label Text="{Binding TaxAmount, StringFormat='{}{0:c}'}" FontSize="16" FontFamily="{x:Static resources:Fonts.HikeLightFont}" HorizontalOptions="End"  VerticalTextAlignment="Center"/>
							<Label Text="{Localize:Translate CloseIconUnicode}" FontSize="14" Margin="2,0,10,0"
										VerticalOptions="Center" HorizontalOptions="End" TextColor="Black">
										<Label.GestureRecognizers>
											<TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:InvoiceViewModel}}, Path=RemoveInvoiceTaxItemCommand, x:DataType=vm:InvoiceViewModel}"
																				CommandParameter="{Binding .}" />
										</Label.GestureRecognizers>
							</Label>
						</StackLayout>
						<BoxView Color="{x:Static resources:AppColors.LightBordersColor}" HeightRequest="0.5" />
					</StackLayout>
				</DataTemplate>
			</CollectionView.ItemTemplate>
		</CollectionView>
	</StackLayout>
</Border>