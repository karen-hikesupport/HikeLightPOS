<?xml version="1.0" encoding="UTF-8"?>
<local:PopupBasePage xmlns="http://schemas.microsoft.com/dotnet/2021/maui" xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                     xmlns:Helpers="clr-namespace:HikePOS.Helpers" x:Class="HikePOS.CustomerDetailPage"
                     xmlns:local="clr-namespace:HikePOS" xmlns:resources="clr-namespace:HikePOS.Resources"
                     xmlns:Localize="clr-namespace:HikePOS;assembly=HikePOS" xmlns:userControls="clr-namespace:HikePOS.UserControls"
                     xmlns:system="clr-namespace:System;assembly=mscorlib" xmlns:vm="clr-namespace:HikePOS.ViewModels"
                    x:DataType="vm:AddCustomerViewModel"
                    xmlns:model="clr-namespace:HikePOS.Models"
                    x:TypeArguments="vm:AddCustomerViewModel" BackgroundColor="{StaticResource PopupBG}">
    <ContentPage.Content>
        <Grid ColumnSpacing="0" RowSpacing="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="{OnIdiom Phone='60',Default='0'}" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="{OnIdiom Phone='0',Default='*'}" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
             <!--Start Ticket #74631 iOS: Credit Note Receipt (FR) by pratik-->
            <!--End Ticket #74631 by pratik-->
              <OnIdiom x:TypeArguments="View">
                 <OnIdiom.Tablet>
                 <StackLayout Spacing="20" Grid.Row="0" Grid.Column="0" VerticalOptions="Start" HorizontalOptions="End" TranslationX="-20" TranslationY="20">
                    <Button Command="{Binding ClosePopupCommand}" Style="{x:Static resources:Styles.PopUpCloseButtonStyle}" />
                    <Button Text="Edit" Command="{Binding EditCommand}" Style="{x:Static resources:Styles.PopUpTextMenuButtonStyle}" HorizontalOptions="End" IsVisible="{Binding EditCustomerVisible}"/>
                   <Button Text="{Localize:Translate StoreCredit_ButtonText}" IsVisible="{Binding HasStoreCreditPermission}" Command="{Binding StoreCreditCommand}" Style="{x:Static resources:Styles.PopUpTextMenuButtonStyle}" HorizontalOptions="End" />
            </StackLayout>
                </OnIdiom.Tablet>
                <OnIdiom.Phone>
                    <StackLayout Spacing="10" Grid.Row="1" Grid.Column="1" Orientation="Horizontal" BackgroundColor="{x:Static resources:AppColors.MainBackgroundColor}" Padding="20,0,20,0">
                   <Button Text="Close" Command="{Binding ClosePopupCommand}" Style="{x:Static resources:Styles.PopUpTextMenuButtonStylePhone}" />
                    <Button Text="Edit" Command="{Binding EditCommand}" Style="{x:Static resources:Styles.PopUpTextMenuButtonStylePhone}"  IsVisible="{Binding EditCustomerVisible}"/>
                   <Button Text="{Localize:Translate StoreCredit_ButtonText}" IsVisible="{Binding HasStoreCreditPermission}" Command="{Binding StoreCreditCommand}" Style="{x:Static resources:Styles.PopUpTextMenuButtonStylePhone}"/>
                    </StackLayout>
                 </OnIdiom.Phone>
             </OnIdiom>
            <Grid  Grid.Row="0" Grid.Column="1" VerticalOptions="FillAndExpand" HorizontalOptions="FillAndExpand" BackgroundColor="{x:Static resources:AppColors.MainBackgroundColor}" >
                <Grid VerticalOptions="FillAndExpand" HorizontalOptions="FillAndExpand" RowSpacing="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="110" />
                        <RowDefinition Height="{OnPlatform Default='31', Android='41'}" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Label Grid.Row="0" Text="{Binding NewCustomer.FullName}" Style="{x:Static resources:Styles.PopupTitleLabelStyle}" />
                    <Grid Grid.Row="1" RowSpacing="0" ColumnSpacing="30" Margin="{OnIdiom Phone='20,0,20,10',Default='30,0,30,10'}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="{OnPlatform Default='30', Android='40'}" />
                            <RowDefinition Height="1" />
                        </Grid.RowDefinitions>
                        <BoxView Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="4" Color="{x:Static resources:AppColors.LightBordersColor}" HeightRequest="1" />
                        <Button Grid.Row="0" Grid.Column="0" Text="Primary info" Style="{x:Static resources:Styles.TabButtonStyle}" Command="{Binding PrimaryInfoCommand}" CommandParameter="custDetail"/>
                        <BoxView IsVisible="{Binding IsPriaryInfoActive}" Grid.Row="1" Grid.Column="0" Color="{x:Static resources:AppColors.HikeColor}" HeightRequest="1" />

                        <Button Grid.Row="0" Grid.Column="1" Text="Sales History"  Style="{x:Static resources:Styles.TabButtonStyle}"  Command="{Binding MoreDetailsCommand}" />

                        <BoxView Grid.Row="1" Grid.Column="1" Color="{x:Static resources:AppColors.HikeColor}" HeightRequest="1" IsVisible="{Binding IsPriaryInfoActive, Converter={Helpers:InverseBoolConverter}}" />

                        <StackLayout Grid.Column="3" Grid.Row="0" Orientation="Horizontal" HorizontalOptions="End" IsVisible="false" >
                            <!--IsVisible="{Binding IsPriaryInfoActive, Converter={Helpers:InverseBoolConverter}}">-->
                            <Button x:Name="FilterStatusButton" Text="{Localize:Translate FilterByStatusText}" Command="{Binding FilterOptionCommand}" Style="{x:Static resources:Styles.FilterByStatusButtonStyle}"/>
                            <Label Text="{Localize:Translate FilterIconUnicode}" FontSize="16" FontFamily="{x:Static resources:Fonts.HikeAwesomeFont}" TextColor="{x:Static resources:AppColors.NavigationBarBackgroundColor}" HorizontalOptions="Start" HorizontalTextAlignment="Start" VerticalOptions="Center" VerticalTextAlignment="Center" Margin="0,3,0,0"/>
                        </StackLayout>
                    </Grid>
                    <Grid Grid.Row="2" VerticalOptions="FillAndExpand" HorizontalOptions="FillAndExpand">
                        <ScrollView IsVisible="{Binding IsPriaryInfoActive}" VerticalOptions="FillAndExpand" HorizontalOptions="FillAndExpand" VerticalScrollBarVisibility="Never">
                            <Grid  RowSpacing="5" ColumnSpacing="30" Margin="{OnIdiom Phone='20,0,20,0',Default='30,0,30,0'}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="30" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="30" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="30" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="30" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="30" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="30" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="30" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Label Grid.Row="0" Grid.Column="0" Text="{Localize:Translate Phone}" FontSize="14" FontFamily="{x:Static resources:Fonts.HikeLightFont}" TextColor="{x:Static resources:AppColors.PrimaryTextColor}" HorizontalOptions="Start" VerticalOptions="EndAndExpand" />
                                <Label Grid.Row="1" Grid.Column="0" Text="{Binding NewCustomer.Phone}" FontSize="16" FontFamily="{x:Static resources:Fonts.HikeLightFont}" TextColor="{x:Static resources:AppColors.PrimaryTextColor}" VerticalTextAlignment="Start">
                                    <Label.Triggers>
                                        <DataTrigger TargetType="Label" Binding="{Binding NewCustomer.Phone, Converter={Helpers:NullValueBoolConverter}}" Value="False">
                                            <Setter Property="Text" Value="-" />
                                        </DataTrigger>
                                        <DataTrigger TargetType="Label" Binding="{Binding NewCustomer.Phone, Converter={Helpers:NullValueBoolConverter}}" Value="True">
                                            <Setter Property="Text" Value="{Binding NewCustomer.Phone}" />
                                        </DataTrigger>
                                    </Label.Triggers>
                                </Label>
                                <Label Margin="0,12,0,0" Grid.Row="0" Grid.Column="1" Text="{Localize:Translate Email}" FontSize="14" FontFamily="{x:Static resources:Fonts.HikeLightFont}" TextColor="{x:Static resources:AppColors.PrimaryTextColor}" HorizontalOptions="Start" VerticalOptions="EndAndExpand" />

                                <Label Grid.Row="1" Grid.Column="1" Text="{Binding NewCustomer.Email}" FontSize="16" FontFamily="{x:Static resources:Fonts.HikeLightFont}" TextColor="{x:Static resources:AppColors.PrimaryTextColor}" VerticalTextAlignment="Start">
                                    <Label.Triggers>
                                        <DataTrigger TargetType="Label" Binding="{Binding NewCustomer.Email, Converter={Helpers:NullValueBoolConverter}}" Value="False">
                                            <Setter Property="Text" Value="-" />
                                        </DataTrigger>
                                        <DataTrigger TargetType="Label" Binding="{Binding NewCustomer.Email, Converter={Helpers:NullValueBoolConverter}}" Value="True">
                                            <Setter Property="Text" Value="{Binding NewCustomer.Email}" />
                                        </DataTrigger>
                                    </Label.Triggers>
                                </Label>
                                <Label Margin="0,12,0,0" Grid.Row="2" Grid.Column="0" Text="{Localize:Translate CustomerCode}" FontSize="14" FontFamily="{x:Static resources:Fonts.HikeLightFont}" TextColor="{x:Static resources:AppColors.PrimaryTextColor}" HorizontalOptions="Start" VerticalOptions="EndAndExpand" />
                                <Label Grid.Row="3" Grid.Column="0" Text="{Binding NewCustomer.CustomerCode}" FontSize="16" FontFamily="{x:Static resources:Fonts.HikeLightFont}" TextColor="{x:Static resources:AppColors.PrimaryTextColor}" VerticalTextAlignment="Start">
                                    <Label.Triggers>
                                        <DataTrigger TargetType="Label" Binding="{Binding NewCustomer.CustomerCode, Converter={Helpers:NullValueBoolConverter}}" Value="False">
                                            <Setter Property="Text" Value="-" />
                                        </DataTrigger>
                                        <DataTrigger TargetType="Label" Binding="{Binding NewCustomer.CustomerCode, Converter={Helpers:NullValueBoolConverter}}" Value="True">
                                            <Setter Property="Text" Value="{Binding NewCustomer.CustomerCode}" />
                                        </DataTrigger>
                                    </Label.Triggers>
                                </Label>
                                <Label Margin="0,12,0,0" Grid.Row="2" Grid.Column="1" Text="{Localize:Translate CustomerGroup}" FontSize="14" FontFamily="{x:Static resources:Fonts.HikeLightFont}" TextColor="{x:Static resources:AppColors.PrimaryTextColor}" HorizontalOptions="Start" VerticalOptions="EndAndExpand" />
                                <Label Grid.Row="3" Grid.Column="1" Text="{Binding NewCustomer.CustomerGroupName}" FontSize="16" FontFamily="{x:Static resources:Fonts.HikeLightFont}" TextColor="{x:Static resources:AppColors.PrimaryTextColor}" VerticalTextAlignment="Start">
                                    <Label.Triggers>
                                        <DataTrigger TargetType="Label" Binding="{Binding NewCustomer.CustomerGroupId, Converter={Helpers:NullValueBoolConverter}}" Value="False">
                                            <Setter Property="Text" Value="-" />
                                        </DataTrigger>
                                        <DataTrigger TargetType="Label" Binding="{Binding NewCustomer.CustomerGroupId, Converter={Helpers:NullValueBoolConverter}}" Value="True">
                                            <Setter Property="Text" Value="{Binding NewCustomer.CustomerGroupName}" />
                                        </DataTrigger>

                                    </Label.Triggers>
                                </Label>
                                <Label Margin="0,12,0,0" Grid.Row="4" Grid.Column="0" Text="{Localize:Translate CustomerSince}" FontSize="14" FontFamily="{x:Static resources:Fonts.HikeLightFont}" TextColor="{x:Static resources:AppColors.PrimaryTextColor}" HorizontalOptions="Start" VerticalOptions="EndAndExpand" />
                                <Label Grid.Row="5" Grid.Column="0" Text="{Binding NewCustomer.CreationTime, StringFormat='{0:D}'}" FontSize="16" FontFamily="{x:Static resources:Fonts.HikeLightFont}" TextColor="{x:Static resources:AppColors.PrimaryTextColor}" VerticalTextAlignment="Start">
                                    <Label.Triggers>
                                        <DataTrigger TargetType="Label" Binding="{Binding NewCustomer.CreationTime, Converter={Helpers:NullValueBoolConverter}}" Value="False">
                                            <Setter Property="Text" Value="-" />
                                        </DataTrigger>
                                        <DataTrigger TargetType="Label" Binding="{Binding NewCustomer.CreationTime, Converter={Helpers:NullValueBoolConverter}}" Value="True">
                                            <Setter Property="Text" Value="{Binding NewCustomer.CreationTime, StringFormat='{0:D}'}" />
                                        </DataTrigger>
                                    </Label.Triggers>
                                </Label>
                                <Label Margin="0,12,0,0" Grid.Row="4" Grid.Column="1" Text="{Localize:Translate DOB}" FontSize="14" FontFamily="{x:Static resources:Fonts.HikeLightFont}" TextColor="{x:Static resources:AppColors.PrimaryTextColor}" HorizontalOptions="Start" VerticalOptions="EndAndExpand" />
                                <Label Grid.Row="5" Grid.Column="1" Text="{Binding NewCustomer.BirthDate, StringFormat='{0:D}'}" FontSize="16" FontFamily="{x:Static resources:Fonts.HikeLightFont}" TextColor="{x:Static resources:AppColors.PrimaryTextColor}" VerticalTextAlignment="Start">
                                    <Label.Triggers>
                                        <DataTrigger TargetType="Label" Binding="{Binding NewCustomer.BirthDate, Converter={Helpers:NullValueBoolConverter}}" Value="False">
                                            <Setter Property="Text" Value="-" />
                                        </DataTrigger>
                                        <!--Start:#50759.by rupesh-->
                                        <DataTrigger TargetType="Label" Binding="{Binding IsDoNotAskForTheYearInTheBirthDateOfTheCustomers}" Value="False">
                                            <Setter Property="Text" Value="{Binding NewCustomer.BirthDate, StringFormat='{0:D}'}" />
                                        </DataTrigger>
                                         <!--End:#50759.by rupesh-->
                                         <!--Start #45386 iPad: Please ignore birthday "year" when add new customer.by rupesh-->         
                                        <DataTrigger TargetType="Label" Binding="{Binding IsDoNotAskForTheYearInTheBirthDateOfTheCustomers}" Value="True">
                                            <Setter Property="Text" Value="{Binding NewCustomer.BirthDate, StringFormat='{0:dddd,dd MMM}'}" />
                                        </DataTrigger>
                                         <!--End #45386.by rupesh-->         
                                    </Label.Triggers>
                                </Label>
                                <Label Margin="0,12,0,0" Grid.Row="6" Grid.Column="0" Text="{Localize:Translate LoyaltyPoints}" FontSize="14" FontFamily="{x:Static resources:Fonts.HikeLightFont}" TextColor="{x:Static resources:AppColors.PrimaryTextColor}" HorizontalOptions="Start" VerticalOptions="EndAndExpand" />
                                <Label Grid.Row="7" Grid.Column="0" Text="{Binding NewCustomer.CurrentLoyaltyBalance}" FontSize="16" FontFamily="{x:Static resources:Fonts.HikeLightFont}" TextColor="{x:Static resources:AppColors.PrimaryTextColor}" VerticalTextAlignment="Start" />
                                <Label Margin="0,12,0,0" Grid.Row="6" Grid.Column="1" Text="{Localize:Translate StoreCredit}" FontSize="14" FontFamily="{x:Static resources:Fonts.HikeLightFont}" TextColor="{x:Static resources:AppColors.PrimaryTextColor}" HorizontalOptions="Start" VerticalOptions="EndAndExpand" />
                                <Label Grid.Row="7" Grid.Column="1" Text="{Binding NewCustomer.CreditBalance, StringFormat='{}{0:c}'}" FontSize="16" FontFamily="{x:Static resources:Fonts.HikeLightFont}" TextColor="{x:Static resources:AppColors.PrimaryTextColor}" VerticalTextAlignment="Start" />
                                <Label Margin="0,12,0,0" Grid.Row="8" Grid.Column="0" Text="{Localize:Translate AvgPurchase}" FontSize="14" FontFamily="{x:Static resources:Fonts.HikeLightFont}" TextColor="{x:Static resources:AppColors.PrimaryTextColor}" HorizontalOptions="Start" VerticalOptions="EndAndExpand" />
                                <Label Grid.Row="9" Grid.Column="0" Text="{Binding NewCustomer.AveragePurchase, StringFormat='{}{0:c}'}" FontSize="16" FontFamily="{x:Static resources:Fonts.HikeLightFont}" TextColor="{x:Static resources:AppColors.PrimaryTextColor}" VerticalTextAlignment="Start">
                                    <!--<Label.Triggers>
	                                        <DataTrigger TargetType="Label" Binding="{Binding NewCustomer.AveragePurchase, Converter={Helpers:NullValueBoolConverter}}" Value="False">
	                                            <Setter Property="Text" Value="-" />
	                                        </DataTrigger>
									    </Label.Triggers>-->
                                </Label>
                                <Label Margin="0,12,0,0" Grid.Row="8" Grid.Column="1" Text="{Localize:Translate TotalPurchase}" FontSize="14" FontFamily="{x:Static resources:Fonts.HikeLightFont}" TextColor="{x:Static resources:AppColors.PrimaryTextColor}" HorizontalOptions="Start" VerticalOptions="EndAndExpand" />
                                <Label Grid.Row="9" Grid.Column="1" Text="{Binding NewCustomer.TotalPurchase, StringFormat='{}{0:c}'}" FontSize="16" FontFamily="{x:Static resources:Fonts.HikeLightFont}" TextColor="{x:Static resources:AppColors.PrimaryTextColor}" VerticalTextAlignment="Start">
                                    <!--<Label.Triggers>
	                                        <DataTrigger TargetType="Label" Binding="{Binding NewCustomer.TotalPurchase, Converter={Helpers:NullValueBoolConverter}}" Value="False">
	                                            <Setter Property="Text" Value="-" />
	                                        </DataTrigger>
									    </Label.Triggers>-->
                                </Label>
                                <Label Margin="0,12,0,0" Grid.Row="10" Grid.Column="0" Text="{Localize:Translate AccountLimit}" FontSize="14" FontFamily="{x:Static resources:Fonts.HikeLightFont}" TextColor="{x:Static resources:AppColors.PrimaryTextColor}" HorizontalOptions="Start" VerticalOptions="EndAndExpand" />
                                <Label Grid.Row="11" Grid.Column="0" Text="{Binding NewCustomer.CreditLimit, StringFormat='{}{0:c}'}" FontSize="16" FontFamily="{x:Static resources:Fonts.HikeLightFont}" TextColor="{x:Static resources:AppColors.PrimaryTextColor}" VerticalTextAlignment="Start">
                                    <!--<Label.Triggers>
	                                        <DataTrigger TargetType="Label" Binding="{Binding NewCustomer.CreditLimit, Converter={Helpers:NullValueBoolConverter}}" Value="False">
	                                            <Setter Property="Text" Value="-" />
	                                        </DataTrigger>
									    </Label.Triggers>-->
                                </Label>
                                <Label Margin="0,12,0,0" Grid.Row="10" Grid.Column="1" Text="{Localize:Translate OutstandingText}" FontSize="14" FontFamily="{x:Static resources:Fonts.HikeLightFont}" TextColor="{x:Static resources:AppColors.PrimaryTextColor}" HorizontalOptions="Start" VerticalOptions="EndAndExpand" />
                                <Label Grid.Row="11" Grid.Column="1" Text="{Binding NewCustomer.OutStandingBalance, StringFormat='{}{0:c}'}" FontSize="16" FontFamily="{x:Static resources:Fonts.HikeLightFont}" TextColor="{x:Static resources:AppColors.PrimaryTextColor}" VerticalTextAlignment="Start">
                                    <!--<Label.Triggers>
	                                        <DataTrigger TargetType="Label" Binding="{Binding NewCustomer.OutStandingBalance, Converter={Helpers:NullValueBoolConverter}}" Value="False">
	                                            <Setter Property="Text" Value="-" />
	                                        </DataTrigger>
									    </Label.Triggers>-->
                                </Label>
                                <Label Margin="0,12,0,0" Grid.Row="12" Grid.Column="0" Text="{Localize:Translate VisitThisMonth}" FontSize="14" FontFamily="{x:Static resources:Fonts.HikeLightFont}" TextColor="{x:Static resources:AppColors.PrimaryTextColor}" HorizontalOptions="Start" VerticalOptions="EndAndExpand" />
                                <Label Grid.Row="13" Grid.Column="0" Text="{Binding NewCustomer.VisitCurrentMonth}" FontSize="16" FontFamily="{x:Static resources:Fonts.HikeLightFont}" TextColor="{x:Static resources:AppColors.PrimaryTextColor}" VerticalTextAlignment="Start">
                                    <!--<Label.Triggers>
	                                        <DataTrigger TargetType="Label" Binding="{Binding NewCustomer.VisitCurrentMonth, Converter={Helpers:NullValueBoolConverter}}" Value="False">
	                                            <Setter Property="Text" Value="-" />
	                                        </DataTrigger>
									    </Label.Triggers>-->
                                </Label>
                                <Label Margin="0,12,0,0" Grid.Row="12" Grid.Column="1" Text="{Localize:Translate AvgMonthlyVisits}" FontSize="14" FontFamily="{x:Static resources:Fonts.HikeLightFont}" TextColor="{x:Static resources:AppColors.PrimaryTextColor}" HorizontalOptions="Start" VerticalOptions="EndAndExpand" />
                                <Label Grid.Row="13" Grid.Column="1" Text="{Binding NewCustomer.AvgMonthlyVisit}" FontSize="16" FontFamily="{x:Static resources:Fonts.HikeLightFont}" TextColor="{x:Static resources:AppColors.PrimaryTextColor}" VerticalTextAlignment="Start">
                                    <!--<Label.Triggers>
	                                        <DataTrigger TargetType="Label" Binding="{Binding NewCustomer.AvgMonthlyVisit, Converter={Helpers:NullValueBoolConverter}}" Value="False">
	                                            <Setter Property="Text" Value="-" />
	                                        </DataTrigger>
									    </Label.Triggers>-->
                                </Label>
                            </Grid>
                        </ScrollView>
                       
                        <Grid IsVisible="{Binding IsPriaryInfoActive, Converter={Helpers:InverseBoolConverter}}"
                             VerticalOptions="FillAndExpand" HorizontalOptions="FillAndExpand" Margin="{OnIdiom Phone='20,10,20,20',Default='30,10,30,20'}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="40" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="0.5" />
                                    <RowDefinition Height="39" />
                                    <RowDefinition Height="0.5" />
                                </Grid.RowDefinitions>
                                <BoxView Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3" BackgroundColor="{x:Static resources:AppColors.NavigationBarBackgroundColor}" HeightRequest="0.5" />
                                <Label Grid.Row="1" Grid.Column="0" Text="Date" FontSize="14" FontFamily="{x:Static resources:Fonts.HikeDefaultFont}" TextColor="{x:Static resources:AppColors.NavigationBarBackgroundColor}" HorizontalTextAlignment="Start" VerticalTextAlignment="Center" Margin="0,0,5,0" />
                                <Label Grid.Row="1" Grid.Column="1" Text="Sale" FontSize="14" FontFamily="{x:Static resources:Fonts.HikeDefaultFont}" TextColor="{x:Static resources:AppColors.NavigationBarBackgroundColor}" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" Margin="0,0,5,0" />
                                <Label Grid.Row="1" Grid.Column="2" Text="Sale amount" FontSize="14" FontFamily="{x:Static resources:Fonts.HikeDefaultFont}" TextColor="{x:Static resources:AppColors.NavigationBarBackgroundColor}" HorizontalTextAlignment="End" VerticalTextAlignment="Center" Margin="0,0,5,0" />
                                <BoxView Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3" Color="{x:Static resources:AppColors.NavigationBarBackgroundColor}" HeightRequest="0.5" />
                            </Grid>
                            <CollectionView Grid.Row="1" BackgroundColor="Transparent" SelectionMode="None"
                                 ItemsSource="{Binding customerInvoices}" Margin="0,10,0,0">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate x:DataType="model:InvoiceDto">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="0.5" />
                                            </Grid.RowDefinitions>
                                            <Label Grid.Row="0" Grid.Column="0" Text="{Binding TransactionDate, StringFormat='{0:D}'}" FontSize="14" FontFamily="{x:Static resources:Fonts.HikeLightFont}" TextColor="{x:Static resources:AppColors.NavigationBarBackgroundColor}" VerticalTextAlignment="Center" Margin="0,12,0,10" />
                                            <Label Grid.Row="0" Grid.Column="1" Text="{Binding Number}" FontSize="14" FontFamily="{x:Static resources:Fonts.HikeLightFont}" TextColor="{x:Static resources:AppColors.NavigationBarBackgroundColor}" VerticalTextAlignment="Center" HorizontalTextAlignment="Center" Margin="0,12,0,10" />
                                            <Label Grid.Row="0" Grid.Column="2" Text="{Binding NetAmount, StringFormat='{}{0:c}'}" FontSize="14" FontFamily="{x:Static resources:Fonts.HikeLightFont}" TextColor="{x:Static resources:AppColors.NavigationBarBackgroundColor}" VerticalTextAlignment="Center" HorizontalTextAlignment="End" Margin="0,12,5,10" />
                                            <BoxView Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Color="{x:Static resources:AppColors.LightBordersColor}" HeightRequest="0.5" />
                                        </Grid>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </Grid>
                    </Grid>
                </Grid>
                <StackLayout HorizontalOptions="End" VerticalOptions="Start" Scale="{Binding IsOpenFilterOptionPopUp}" IsVisible="{OnPlatform Android={Binding IsOpenFilterOptionPopUp,Converter={Helpers:IntegerToBoolConverter}},Default=True}" Margin="0,150,30,0">
                    <local:ParkSaleFilterOptionMenuView x:Name="FilterOptionMenu" ItemChanged="FilterOptionHandle_ItemChanged" />
                </StackLayout>
                <!--<ActivityIndicator IsVisible="{Binding IsBusy}" IsRunning="{Binding IsBusy}" Scale="2" Color="Black" Margin="0,20" VerticalOptions="Center" HorizontalOptions="Center"/>-->
            </Grid>
            
        </Grid>
    </ContentPage.Content>
</local:PopupBasePage>