<?xml version="1.0" encoding="UTF-8"?>
<local:PopupBasePage
        xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
        xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
        x:Class="HikePOS.SignaturePromptPage" 
        xmlns:local="clr-namespace:HikePOS"  
        xmlns:resources="clr-namespace:HikePOS.Resources"  
        FlowDirection="LeftToRight"
        xmlns:vm="clr-namespace:HikePOS.ViewModels"
        x:TypeArguments="vm:BaseViewModel"
        Title="Title"
        x:Name="PopupPage">
    <ContentPage.Content>
        <ScrollView>
            <Grid RowSpacing="0" ColumnSpacing="10" Padding="10" VerticalOptions="Center" HorizontalOptions="Center" BackgroundColor="White">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="150"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="1"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="1"/>
                    <RowDefinition Height="50"/>
                </Grid.RowDefinitions>
                <Label Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Text="{Binding Source={x:Reference PopupPage}, Path=Title}" FontSize="18" FontFamily="{x:Static resources:Fonts.HikeBoldFont}" TextColor="{x:Static resources:AppColors.PrimaryTextColor}" VerticalTextAlignment="Center" HorizontalTextAlignment="Center" HorizontalOptions="Center" VerticalOptions="Start" Margin="10" />
                <BoxView Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" BackgroundColor="{x:Static resources:AppColors.LightBordersColor}" />
                <Label x:Name="DescriptionLabel" IsVisible="false" Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" FontSize="16" FontFamily="{x:Static resources:Fonts.HikeLightFont}" TextColor="{x:Static resources:AppColors.PrimaryTextColor}" VerticalTextAlignment="Center" HorizontalTextAlignment="Center" HorizontalOptions="Center" VerticalOptions="Start" Margin="10,10,10,0" />
                <Border x:Name="frameSignaturePad" Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" 
                     Style="{x:Static resources:Styles.FormRoundBorderStyle}" HeightRequest="240" Padding="0" 
                     Margin="0,10,0,10" VerticalOptions="Start">
                     <!--<component:SignaturePadView
                        x:Name="singatureView"
                        BackgroundColor="White"
                        CaptionText="Sign here"
                        ClearText="Clear"
                        PromptText="x"
                        StrokeWidth="2" 
                    />-->
                </Border>
                <BoxView Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" BackgroundColor="{x:Static resources:AppColors.LightBordersColor}" />
                <Button x:Name="NoButton" Grid.Row="5" Grid.Column="0" HeightRequest="50" BackgroundColor="White" BorderColor="{x:Static resources:AppColors.RedButtonBackgroundColor}" BorderWidth="1" FontSize="18" FontFamily="{x:Static resources:Fonts.HikeDefaultFont}" CornerRadius="5" TextColor="{x:Static resources:AppColors.RedButtonBackgroundColor}" Clicked="CancelHandle_Clicked" Margin="0,10,0,0" />
                <Button x:Name="YesButton" Grid.Row="5" Grid.Column="1" HeightRequest="50" BackgroundColor="White" BorderColor="{x:Static resources:AppColors.HikeColor}" BorderWidth="1" FontSize="18" FontFamily="{x:Static resources:Fonts.HikeDefaultFont}" CornerRadius="5" TextColor="{x:Static resources:AppColors.HikeColor}" Clicked="SaveHandle_Clicked" Margin="0,10,0,0" />
            </Grid>
        </ScrollView>
    </ContentPage.Content>
</local:PopupBasePage>
