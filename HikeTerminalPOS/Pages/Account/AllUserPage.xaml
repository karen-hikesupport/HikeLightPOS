<?xml version="1.0" encoding="UTF-8"?>
<local:PopupBasePage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
        xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml" 
		x:Class="HikePOS.AllUserPage" 
		xmlns:local="clr-namespace:HikePOS" 
		xmlns:resources="clr-namespace:HikePOS.Resources" 
		xmlns:Localize="clr-namespace:HikePOS;assembly=HikePOS" 
		xmlns:userControls="clr-namespace:HikePOS.UserControls"
        xmlns:model="clr-namespace:HikePOS.Models"
        xmlns:vm="clr-namespace:HikePOS.ViewModels"
        x:TypeArguments="vm:AllUserViewModel"
        x:DataType="vm:AllUserViewModel"
        x:Name="alluserpage"
		xmlns:Helpers="clr-namespace:HikePOS.Helpers" BackgroundColor="{StaticResource PopupBG}">
       <ContentPage.Content>
        <Grid ColumnSpacing="0" RowSpacing="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="{OnIdiom Phone='0',Default='*'}" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid RowDefinitions="120,*"  Grid.Row="0" Grid.Column="1" BackgroundColor="White">
                
                <Label Grid.Row="0" Text="Who is selling?" FontSize="16" FontFamily="{x:Static resources:Fonts.HikeBoldFont}" TextColor="{x:Static resources:AppColors.DarkTextColor}" HorizontalOptions="CenterAndExpand" VerticalOptions="Start" Margin="10,50,10,50" />
               
                <ContentView Grid.Row="1" BackgroundColor="{x:Static resources:AppColors.MainBackgroundColor}" VerticalOptions="FillAndExpand">
                    <CollectionView x:Name="UserListView" 
                                VerticalOptions="FillAndExpand" 
                                HorizontalOptions="FillAndExpand"                                
                                Margin="20" SelectionChangedCommand="{Binding UserSelectedCommand}" 
                                SelectedItem="{Binding SelectedUserDto}"
                                ItemsSource="{Binding Users}"
                                SelectionMode="Single">
                        <CollectionView.ItemsLayout>
                            <GridItemsLayout Orientation="Vertical" Span="3" VerticalItemSpacing="5" HorizontalItemSpacing="5"/> 
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="model:UserListDto">
                                    <ContentView>
                                        <Grid ColumnSpacing="0" RowSpacing="0" Padding="0.5">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="30" />
                                                <RowDefinition Height="20" />
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Border StrokeShape="RoundRectangle 45,45,45,45" Grid.Row="0" Grid.Column="0" HorizontalOptions="Center" HeightRequest="90" WidthRequest="90" Stroke="{x:Static resources:AppColors.LightBordersColor}" Padding="0">
                                                <Grid BackgroundColor="{x:Static resources:AppColors.ItemBackgroundColor}" VerticalOptions="FillAndExpand" HorizontalOptions="FillAndExpand">
                                                    <Label Text="{Binding FullName, Converter={Helpers:StringToAvtarNameConverter}}" TextColor="White" FontSize="30" FontFamily="{x:Static resources:Fonts.HikeLightFont}" VerticalTextAlignment="Center" HorizontalTextAlignment="Center" VerticalOptions="FillAndExpand" HorizontalOptions="FillAndExpand"/>
                                                    <Image 
                                                            Aspect="Fill" 
                                                            VerticalOptions="FillAndExpand" 
                                                            HorizontalOptions="FillAndExpand"
                                                            >
                                                            <Image.Source>
                                                                <UriImageSource Uri="{Binding ProfilePictureId, Converter={Helpers:GuidToImageConverter}, ConverterParameter=User_Medium}" 
                                                                    CacheValidity="30" 
                                                                    CachingEnabled="true"/>
                                                            </Image.Source>
                                                        </Image>
                                                </Grid>
                                            </Border>
                                            <ContentView Grid.Row="1" Grid.Column="0">
                                                <Label Text="{Binding FullName}" Style="{x:Static resources:Styles.EntersaleItemTitleLabelStyle}" Margin="10,10,10,0" />
                                            </ContentView>
                                            <ContentView Grid.Row="2" Grid.Column="0">
                                                <Label Text="{Binding Roles[0].RoleName}" Style="{x:Static resources:Styles.EntersaleItemTitleLabelStyle}" Margin="10,0,10,0" />
                                            </ContentView>
                                        </Grid>
                                    </ContentView>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </ContentView>
            </Grid>
        </Grid>
    </ContentPage.Content>
</local:PopupBasePage>
