<?xml version="1.0" encoding="UTF-8"?>
<local:BaseContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
        xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml" 
		x:Class="HikePOS.TwoFactorPage" 
		xmlns:local="clr-namespace:HikePOS" 
		xmlns:resources="clr-namespace:HikePOS.Resources"
		xmlns:Localize="clr-namespace:HikePOS;assembly=HikePOS"
		xmlns:userControls="clr-namespace:HikePOS.UserControls" 
		xmlns:Helpers="clr-namespace:HikePOS.Helpers"
        xmlns:vm="clr-namespace:HikePOS.ViewModels"
        x:TypeArguments="vm:TwoFactorViewModel"
        x:DataType="vm:TwoFactorViewModel"
		xmlns:behaviors="clr-namespace:HikePOS.Behaviors" 
		xmlns:enums="clr-namespace:HikePOS.Enums" 
		BackgroundColor="White">
        <Grid VerticalOptions="FillAndExpand" HorizontalOptions="FillAndExpand">
            <Grid RowSpacing="0" ColumnSpacing="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="20*" />
                            <RowDefinition Height="80*" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
				        	<ColumnDefinition Width="{OnIdiom Phone='10*',Default='30*'}" />
				    	    <ColumnDefinition Width="{OnIdiom Phone='80*',Default='40*'}"/>
					        <ColumnDefinition Width="{OnIdiom Phone='10*',Default='30*'}" />
                        </Grid.ColumnDefinitions>
                <StackLayout Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3" VerticalOptions="FillAndExpand" HorizontalOptions="FillAndExpand">
                    <Label Text="Verify Security Code" Style="{x:Static resources:Styles.SetUpScreenTitleLabelStyle}"/>
                </StackLayout>
                <ContentView Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" BackgroundColor="{x:Static resources:AppColors.LoginBackgroundColor}"></ContentView>
                <Grid Grid.Row="1" Grid.Column="1" RowSpacing="6" VerticalOptions="Center">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="60" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="60" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <StackLayout Grid.Row="0" Orientation="Horizontal">
                        <Label Text="Enter the verification code sent to you." Style="{x:Static resources:Styles.CheckboxLableStyle}" FontSize="20"/>
                        <Label Style="{x:Static resources:Styles.CheckboxLableStyle}" HeightRequest="24">
                            <Label.FormattedText>
                                <FormattedString>
                                    <Span Text="*" TextColor="Red"/>
                                </FormattedString>
                            </Label.FormattedText>
                        </Label>
                    </StackLayout>
                    <Border Grid.Row="1" Style="{x:Static resources:Styles.FormRoundBorderStyle}" HeightRequest="60" Padding="2,0,0,0">
                            <userControls:BorderLessEntry x:Name="txtCode" Text="{Binding Code}" Grid.Row="0" Grid.Column="0" 
                                Placeholder="Enter code" Style="{x:Static resources:Styles.FormBigEntryStyle}" 
                                ReturnType="Next" ReturnCommand="{Binding ReturnCommand}"
                                Keyboard="Numeric"/>
                    </Border>

                    <Grid Grid.Row="2" ColumnDefinitions="50,*" Margin="0,20">
                        <Border Grid.Row="1" StrokeShape="RoundRectangle 0"  HeightRequest="30" WidthRequest="30" 
                            Stroke="{x:Static resources:AppColors.ProductBlackColor}"  Margin="0" Padding="3" VerticalOptions="Start">
                            <Image x:Name="imgcheck" IsVisible="{Binding IsRemember}" HeightRequest="24" WidthRequest="24" Source="check_icon.png" 
                                HorizontalOptions="Center" VerticalOptions="Center"/>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="TapGestureRecognizer_Tapped1" NumberOfTapsRequired="1"/>
                            </Border.GestureRecognizers>
                        </Border>
                        <Label Grid.Column="1" Text="Skip two-factor authentication on this device. Your device will remember this preference as long as device (cache) is not cleared."
                            Style="{x:Static resources:Styles.CheckboxLableStyle}"
                            HorizontalTextAlignment="Start" HorizontalOptions="Center"
                            VerticalOptions="Start" FontSize="20" MaxLines="5" LineBreakMode="WordWrap"/>
                    </Grid>

                    <Button Grid.Row="3" Command="{Binding SubmitButtonCommand}" Text="{Localize:Translate Submit_ButtonText}" IsEnabled="True"
                         Margin="0,10,0,0" Style="{x:Static resources:Styles.LoginSignupButtonStyle}">
                            <!-- <Button.Triggers>
                                <DataTrigger TargetType="Button" Binding="{Binding Source={x:Reference txtCode}, Path=Text.Length, Converter={Helpers:MultiTriggerConverter}}" Value="true" >
                                    <Setter Property="IsEnabled" Value="True" />
                                </DataTrigger>
                            </Button.Triggers> -->
                        </Button>
                    <StackLayout Grid.Row="4" VerticalOptions="CenterAndExpand" HorizontalOptions="CenterAndExpand" Orientation="Horizontal" Margin="0,20,0,0">
                        <Label Text="Back to" Style="{x:Static resources:Styles.LoginSignupLinkStyle}" FontSize="20"/>
                        <Label Text="{Localize:Translate Login_ButtonText}" Style="{x:Static resources:Styles.LoginSignupLinkStyle}" TextDecorations="Underline" FontSize="20"/>
                        <StackLayout.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding NavigateToBackCommand}" />
                        </StackLayout.GestureRecognizers>
                    </StackLayout>
                </Grid>
            </Grid>
        </Grid>
</local:BaseContentPage>