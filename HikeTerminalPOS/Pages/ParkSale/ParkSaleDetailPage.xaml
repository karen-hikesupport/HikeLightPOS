<?xml version="1.0" encoding="UTF-8"?>
<local:PopupBasePage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                    x:Class="HikePOS.ParkSaleDetailPage"
                    xmlns:local="clr-namespace:HikePOS"
                    xmlns:resources="clr-namespace:HikePOS.Resources"
                    xmlns:Localize="clr-namespace:HikePOS;assembly=HikePOS"
                    xmlns:vm="clr-namespace:HikePOS.ViewModels"
                    x:TypeArguments="vm:ParkSaleDetailViewModel"
                    xmlns:userControls="clr-namespace:HikePOS.UserControls"
                    xmlns:Helpers="clr-namespace:HikePOS.Helpers"
                    xmlns:model="clr-namespace:HikePOS.Models"
                    x:Name="detailpage"
                    x:DataType="vm:ParkSaleDetailViewModel"
                    xmlns:behaviors="clr-namespace:HikePOS.Behaviors"
                    Title="{Binding Title}" BackgroundColor="{StaticResource PopupPageBG}"
                    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit">
    <ContentPage.Resources>
        <Style TargetType="Grid">
            <Setter Property="VisualStateManager.VisualStateGroups">
                <VisualStateGroupList>
                    <VisualStateGroup x:Name="CommonStates">
                        <VisualState x:Name="Normal"/>
                        <VisualState x:Name="Selected">
                            <VisualState.Setters>
                                <Setter Property="BackgroundColor"
                                        Value="#f7f5f5"/>
                            </VisualState.Setters>
                        </VisualState>
                    </VisualStateGroup>
                </VisualStateGroupList>
            </Setter>
        </Style>
    </ContentPage.Resources>
