                <local:GiftReceipt x:Name="GiftReceiptView" Scale="0" Grid.ColumnSpan="3" Grid.Column="0" HorizontalOptions="Start"/>
                <local:DeliveryDocketReceipt x:Name="DeliveryDocketReceiptView" Scale="0" Grid.ColumnSpan="3" Grid.Column="0" HorizontalOptions="Start"/> -->

                <ContentView Content="{Binding PrintReceiptSummaryView}"
                             Scale="0"
                             Grid.ColumnSpan="3"
                             Grid.Column="0"
                             HorizontalOptions="Start"/>
                <ContentView Content="{Binding GiftReceiptView}"
                             Scale="0"
                             Grid.ColumnSpan="3"
                             Grid.Column="0"
                             HorizontalOptions="Start"/>
                <ContentView Content="{Binding DeliveryDocketReceiptView}"
                             Scale="0"
                             Grid.ColumnSpan="3"
                             Grid.Column="0"
                             HorizontalOptions="Start"/>
                <!--Start #84293 iOS - Feature:- Expand Pick & Pack & Order Full fill from multiple location by Pratik-->
                <ContentView Content="{Binding PickAndPackPrint}"
