                                                           Text="{Binding Title}"
                                                           HorizontalTextAlignment="Start"
                                                           Style="{x:Static resources:Styles.TableItemLabelStyle}"/>
                                                    <Label Grid.Row="0"
                                                           Grid.Column="2"
                                                           Text="{Binding Quantity}"
                                                           HorizontalTextAlignment="Start"
                                                           Style="{x:Static resources:Styles.TableItemLabelStyle}"/>
                                                    <Label Grid.Row="0"
                                                           Grid.Column="3"
                                                           Text="{Binding TotalAmount, StringFormat='{}{0:c}'}"
                                                           HorizontalTextAlignment="Start"
                                                           Style="{x:Static resources:Styles.TableItemLabelStyle}">
                                                        <!--Ticket #7760 Start:Rounding issue in Arabic language.By Nikhil.-->
                                                        <Label.Triggers>
                                                            <DataTrigger TargetType="Label"
                                                                         Binding="{Binding Source={RelativeSource AncestorType={x:Type vm:ParkSaleDetailViewModel}}, Path=IsArabicCulture, x:DataType=vm:ParkSaleDetailViewModel}"
                                                                         Value="True">
                                                                <Setter Property="Text"
                                                                        Value="{Binding TotalAmount, StringFormat='{}{0:c2}'}"/>
                                                            </DataTrigger>
                                                        </Label.Triggers>
                                                    </Label>
                                                    <!--#Ticket #7760 End:By Nikhil.-->
                                                    <Label Grid.Row="0"
                                                           Grid.Column="4"
                                                           Text="{Binding TransactionStoreDate, StringFormat='{0:f}'}"
                                                           HorizontalTextAlignment="Start"
                                                           Style="{x:Static resources:Styles.TableItemLabelStyle}"/>
                                                    <Label Grid.Row="0"
                                                           Grid.Column="5"
                                                           Text="{Binding UserBy}"
                                                           HorizontalTextAlignment="End"
                                                           Style="{x:Static resources:Styles.TableItemLabelStyle}"/>
                                                    <BoxView Grid.Row="1"
                                                             Grid.Column="0"
                                                             Grid.ColumnSpan="6"
                                                             Color="{x:Static resources:AppColors.LightBordersColor}"
                                                             HeightRequest="0.5"/>
                                                </Grid>
                                            </DataTemplate>
                                        </BindableLayout.ItemTemplate>
                                    </VerticalStackLayout>
                                </userControls:ExpandCollapseView.ContainerContent>
                            </userControls:ExpandCollapseView>
                        </VerticalStackLayout>
                    </ScrollView>
                </StackLayout>
                <!--<local:InvoiceReceiptView Grid.Row="0" Grid.Column="1" x:Name="PrintReceiptSummaryView"/>-->

                <!--Ticket start:#37033 Android :: Feature request :: Allow to add multiple email address.by rupesh-->
                <StackLayout Grid.Row="0"
                             Grid.RowSpan="2"
                             Grid.Column="{OnIdiom Phone='2',Default='0'}"
                             Spacing="8"
                             VerticalOptions="{OnIdiom Phone='FillAndExpand',Default='StartAndExpand'}"
                             HorizontalOptions="{OnIdiom Phone='FillAndExpand',Default='End'}"
                             TranslationY="{OnIdiom Phone='0',Default='140'}"
                             BackgroundColor="{OnIdiom Phone='#50000000',Default='Transparent'}"
                             IsVisible="{Binding IsFrmEmailVisible}"
                             Padding="{OnIdiom Phone='0,70,0,70',Default='0'}">
                    <!--Ticket start:#38877 iPad: Feature request - Add Gift Receipt Button on Checkout Page.by rupesh-->
                    <StackLayout  Orientation="Horizontal"
                                  Spacing="0"
                                  HorizontalOptions="Center">
                        <Button Text="Tax Invoice/Receipt"
                                IsVisible="{Binding IsToPrintGiftReceipt}"
                                Command="{Binding TaxInvoiceReceiptClickedHandleCommand}"
                                Style="{x:Static resources:Styles.PaymentPrintButtonStyle}"
                                FontSize="{OnIdiom Phone='14',Default='18'}"
                                WidthRequest="{OnIdiom Phone='150',Default='200'}"
                                HeightRequest="50"/>
                        <Button Text="Tax Invoice/Receipt"
                                IsVisible="{Binding IsToPrintGiftReceipt, Converter={Helpers:InverseBoolConverter}}"
                                Command="{Binding TaxInvoiceReceiptClickedHandleCommand}"
                                Style="{x:Static resources:Styles.PaymentAddNewSaleButtonStyle}"
                                FontSize="{OnIdiom Phone='14',Default='18'}"
                                WidthRequest="{OnIdiom Phone='150',Default='200'}"
                                HeightRequest="50"/>
                        <Button Text="Gift receipt"
                                IsVisible="{Binding IsToPrintGiftReceipt, Converter={Helpers:InverseBoolConverter}}"
                                Command="{Binding GiftReceiptClickedHandleCommand}"
                                Style="{x:Static resources:Styles.PaymentPrintButtonStyle}"
                                FontSize="{OnIdiom Phone='14',Default='18'}"
                                WidthRequest="{OnIdiom Phone='150',Default='200'}"
                                HeightRequest="50"/>
                        <Button Text="Gift receipt"
                                IsVisible="{Binding IsToPrintGiftReceipt}"
                                Command="{Binding GiftReceiptClickedHandleCommand}"
                                Style="{x:Static resources:Styles.PaymentAddNewSaleButtonStyle}"
                                WidthRequest="{OnIdiom Phone='150',Default='200'}"
                                FontSize="{OnIdiom Phone='14',Default='18'}"
                                HeightRequest="50"/>
                    </StackLayout>
                    <Border Style="{x:Static resources:Styles.FormRoundBorderStyle}"
                             Padding="10,5" IsVisible="{Binding IsEmailWithPayLinkVisible}"
                             WidthRequest="{OnIdiom Phone='300',Default='400'}"
                             HeightRequest="60">
                            <Grid ColumnDefinitions="*,Auto">
                                <Label Text="Email receipt with pay link" Style="{x:Static resources:Styles.SettingsOptionTitleLabelStyle}" />
                                <userControls:CustomSwitch HorizontalOptions="End" VerticalOptions="Center" IsToggled="{Binding IsEmailWithPayLink}" >
                                </userControls:CustomSwitch>
                            </Grid>
                    </Border>                    
                    <!--Ticket end:#38877 .by rupesh-->
                    <StackLayout Spacing="5"
                                 WidthRequest="{OnIdiom Phone='300',Default='400'}"
                                 Orientation="Vertical"
                                 HorizontalOptions="{OnIdiom Phone='Center',Default='End'}"
                                 VerticalOptions="FillAndExpand">
                        <Border x:Name="frmEmail"
                                Style="{x:Static resources:Styles.FormRoundBorderStyle}"
                                Padding="2,0,0,0"
                                WidthRequest="{OnIdiom Phone='300',Default='400'}"
                                HeightRequest="60"
                                VerticalOptions="Start">
                            <userControls:BorderLessEntry Focused="txtEmail_Focused"
                                                          Completed="txtEmail_Completed"
                                                          Placeholder="{Localize:Translate Email_Placeholder}"
                                                          Keyboard="Email"
                                                          x:Name="txtEmail"
                                                          Text="{Binding CustomerEMailId}"
                                                          IsEnabled="{Binding EmailIsEnabled}"
                                                          Style="{x:Static resources:Styles.FormBigEntryStyle}"/>
                        </Border>
                        <CollectionView x:Name="SelectedEmailList"
                                  IsVisible="{Binding IsSelectedEmailListVisible}"
                                  ItemsSource="{Binding SelectedEmails}"
                                  SelectionMode="None"
                                  BackgroundColor="Transparent"
                                  VerticalOptions="{OnIdiom Phone='Start',Default='FillAndExpand'}"
                                  WidthRequest="{OnIdiom Phone='300',Default='400'}"
                                  HeightRequest="280">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="x:String">
                                    <StackLayout HeightRequest="70" BackgroundColor="White">
                                        <Border Margin="10,5,10,5"
                                                StrokeShape="RoundRectangle 5"
                                                Padding="0">
                                            <StackLayout Margin="10"
                                                            Orientation="Horizontal"
                                                            VerticalOptions="Center"
                                                            HorizontalOptions="EndAndExpand">
                                                <Label Text="{Binding .}"
                                                        VerticalTextAlignment="Center"></Label>
                                                <ImageButton Padding="3"
                                                                WidthRequest="20"
                                                                Source="close"
                                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ParkSaleDetailViewModel}}, Path=RemoveEmailClickedHandleCommand, x:DataType=vm:ParkSaleDetailViewModel}"
                                                                CommandParameter="{Binding .}"></ImageButton>
                                            </StackLayout>
                                        </Border>
                                    </StackLayout>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </StackLayout>
                    <StackLayout  Orientation="Horizontal"
                                  Spacing="30"
                                  HorizontalOptions="Center"
                                  IsVisible="{OnIdiom Phone='True',Default='False'}">
                        <Button Text="Close"
                                Command="{Binding CloseEmailViewCommand}"
                                Style="{x:Static resources:Styles.PaymentPrintButtonStyle}"
                                CornerRadius="5"
                                WidthRequest="120"
                                FontSize="16"
                                HeightRequest="50"/>
                        <Button Text="Send"
                                Command="{Binding EmailHandleClickedCommand}"
                                Style="{x:Static resources:Styles.PaymentPrintButtonStyle}"
                                CornerRadius="5"
                                WidthRequest="120"
                                FontSize="16"
                                HeightRequest="50"/>
                    </StackLayout>
                    <StackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="TapGestureRecognizer_Tapped"/>
                    </StackLayout.GestureRecognizers>
                </StackLayout>
                <!--Ticket end:#32389 #37033 .by rupesh-->

                <!--Ticket start:#40703 iPad: customer search and add customer option should be show in sales history.by rupesh-->
                <BoxView Grid.Row="0"
                         Grid.Column="0"
                         Grid.ColumnSpan="3"
                         Scale="{Binding IsOpenBackground}"
                         IsVisible="{OnPlatform Android={Binding IsOpenBackground,Converter={Helpers:IntegerToBoolConverter}},Default=True}">
                    <BoxView.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding BackgroundHandleTappedCommand}"/>
                    </BoxView.GestureRecognizers>
                </BoxView>
                <ContentView Grid.Row="0"
                             Grid.Column="2"
                             Margin="{OnIdiom Phone='10,140,10,0',Default='100,140,100,0'}"
                             Scale="{Binding CustomerModel.IsOpenSearchCustomerPopUp}"
                             VerticalOptions="Start"
                             HorizontalOptions="FillAndExpand"
                             IsVisible="{OnPlatform Android={Binding CustomerModel.IsOpenSearchCustomerPopUp,Converter={Helpers:IntegerToBoolConverter}},Default=True}">
                    <local:SearchCustomerView x:Name="CustomerPopup"
                                              BindingContext="{Binding CustomerModel}"
                                              VerticalOptions="Start"
                                              HorizontalOptions="FillAndExpand"/>
                </ContentView>
                <!--Ticket end:#40703 .by rupesh-->
            </Grid>
        </Grid>
    </ContentPage.Content>
</local:PopupBasePage>