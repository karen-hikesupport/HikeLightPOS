                                                     Binding="{Binding Invoice.Status}"
                                                     Value="11">
                                            <Setter Property="IsVisible"
                                                    Value="false"/>
                                        </DataTrigger> -->
                                        <!--Ticket end:#22406 Quote sale.by rupesh-->
                                    <!-- </Button.Triggers>
                                </Button> -->

                                <Button Text="{Localize:Translate RefundText}"
                                        Padding="5,0"
                                        IsVisible="{Binding IsHavingRefund}"
                                        Command="{Binding RefundHandleClickedCommand}"
                                        Style="{x:Static resources:Styles.PopUpTextMenuButtonStylePhone}"
                                        TextColor="Red"/>
                                <Button Text="{Localize:Translate ExchangeText}"
