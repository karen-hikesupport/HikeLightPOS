                                        IsVisible="false"
                                        Command="{Binding ClickedMenuCommand}"
                                        CommandParameter="PickAndPack"
                                        Style="{x:Static resources:Styles.PopUpTextMenuButtonStyle}"
                                        HorizontalOptions="End">
                                    <Button.Triggers>
                                        <DataTrigger TargetType="Button"
                                                     Binding="{Binding Invoice.StatusText}"
                                                     Value="Awaiting fulfillment">
                                            <Setter Property="IsVisible"
                                                    Value="true"/>
                                        </DataTrigger>
                                        <!--Start #84293 iOS - Feature:- Expand Pick & Pack & Order Full fill from multiple location by Pratik-->
                                        <DataTrigger TargetType="Button"
                                                     Binding="{Binding Invoice.StatusText}"
                                                     Value="Partial Fulfilled">
                                            <Setter Property="IsVisible"
                                                    Value="true"/>
                                        </DataTrigger>
                                        <!--End #84293 by Pratik-->
                                    </Button.Triggers>
                                </Button>
                                <!--Ticket end:#58490 .by rupesh-->
                                <!--Ticket start:#84289 IOS-Feature:-Ability to re-open Backorders and apply partial payments at any time. by rupesh-->
                                <Button Text="Edit"
                                        Padding="0"
                                        IsVisible="false"
                                        Command="{Binding ClickedMenuCommand}"
                                        CommandParameter="Edit"
                                        Style="{x:Static resources:Styles.PopUpTextMenuButtonStyle}"
                                        HorizontalOptions="End">
                                    <Button.Triggers>
                                        <DataTrigger TargetType="Button"
                                                     Binding="{Binding Invoice.Status}"
                                                     Value="6">
                                            <Setter Property="IsVisible"
                                                    Value="true"/>
                                        </DataTrigger>
                                    </Button.Triggers>
                                </Button>
                                <!--Ticket end:#84289. by rupesh-->
                            </StackLayout>
                        </ScrollView>
                    </OnIdiom.Tablet>
                    <OnIdiom.Phone>
