                                                     Value="4">
                                            <Setter Property="IsVisible"
                                                    Value="false"/>
                                        </DataTrigger> -->

                                        <!--Ticket start:#22406 Quote sale.by rupesh-->
                                        <!-- <DataTrigger TargetType="Button"
                                                     Binding="{Binding Invoice.Status}"
                                                     Value="11">
                                            <Setter Property="IsVisible"
                                                    Value="false"/>
                                        </DataTrigger> -->
                                        <!--Ticket end:#22406 Quote sale.by rupesh-->

