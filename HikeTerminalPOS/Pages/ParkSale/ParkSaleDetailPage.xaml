                                <Button Text="Duplicate"
                                        Padding="0"
                                        IsEnabled="{Binding IsEnableInvoiceDuplicate}"
                                        IsVisible="{Binding IsShowInvoiceDuplicate}"
                                        Command="{Binding DuplicateInvoiceCommand}"
                                        Style="{x:Static resources:Styles.PopUpTextMenuButtonStylePhone}"/>
                                <!--Ticket start:#22406 Quote sale.by rupesh-->
