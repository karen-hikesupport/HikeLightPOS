                <!--Ticket end:#39040.by rupesh-->
                <StackLayout x:Name="rootview"  Grid.Row="0" Grid.Column="2" Spacing="0" BackgroundColor="White" Padding="0,0,0,40" >
                    <Label x:Name="InvoiceNumberLabel" Text="{Binding Invoice.Number, StringFormat='Sale# {0}'}" Style="{x:Static resources:Styles.PopupTitleLabelStyle}"/>
                    <!--#94565-->
                        <HorizontalStackLayout Spacing="4" HorizontalOptions="Center" Margin="0,-10,0,5" IsVisible="{Binding Invoice.FloorTableName, Converter={Helpers:NullValueBoolConverter}}">
                            <Image Source="detailtabel" HeightRequest="20" WidthRequest="20" VerticalOptions="Center" IsVisible="False">
                                 <Image.Triggers>
                                    <DataTrigger TargetType="Image" Binding="{Binding Invoice.FloorTableName, Converter={Helpers:NullValueBoolConverter}}" Value="true">
                                        <Setter Property="IsVisible" Value="true" />
                                    </DataTrigger>
                                </Image.Triggers>
                            </Image>
                            <Label 
                                FontSize="16" TextColor="Black"
                                VerticalTextAlignment="Center" 
                                Text="{Binding Invoice.FloorTableName}"/>
                        </HorizontalStackLayout>
                    <!--#94565-->
                    <Label Text="{Localize:Translate CustomerText}" Style="{x:Static resources:Styles.PopupSaleDetailCustomerTitleLabelStyle}" />
                    <StackLayout Orientation="Horizontal" Spacing="10" HorizontalOptions="Center">
                        <!--Ticket start:#49894 iPad: Customer name UI issue.by rupesh-->
                        <!--Ticket start:#45371 change an invoice after it’s printed.by rupesh-->
                        <Label x:Name="CustomerName"
                               Text="{Binding Invoice.CustomerName}"
                               IsEnabled="{Binding CustomerNameIsEnabled}"
                               Style="{x:Static resources:Styles.PopupSaleDetailCustomerNameLabelStyle}"
                               HorizontalOptions="Center"
                               VerticalOptions="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding CustomerModel.EditCustomerCommand}"
                                                      CommandParameter="{Binding Invoice.CustomerDetail}"/>
                            </Label.GestureRecognizers>
                        </Label>
                        <!--<Button Text="{Binding Invoice.CustomerName}" Style="{x:Static resources:Styles.PopupSaleDetailCustomerNameButtonStyle}" HorizontalOptions="Center" Command="{Binding CustomerModel.EditCustomerCommand}" CommandParameter="{Binding Invoice.CustomerDetail}" />-->
                        <!--Ticket end:#49894 iPad: Customer name UI issue.by rupesh-->
                        <Button Text="✕"
                                x:Name="CustomerRemoveButton"
                                Style="{x:Static resources:Styles.TableHeaderIconButtonStyle}"
                                HorizontalOptions="Start"
                                VerticalOptions="Center"
                                Command="{Binding CustomerModel.RemoveCustomerCommand}"
                                CommandParameter="{Binding Invoice.CustomerDetail}"
                                IsVisible="{Binding IsCustomerRemoveVisible}"/>
                        <!--Ticket Start:#76072 iPAD: Quote sale should not allow t remove customer from sales history; Only allow to change from existing one.by Pratik-->
                        <Button Text="{Localize:Translate EditIconUnicode}"
                                x:Name="CustomerChangedButton"
                                TextColor="Black"
                                IsVisible="False"
                                Style="{x:Static resources:Styles.TableHeaderIconButtonStyle}"
                                HorizontalOptions="Start"
                                VerticalOptions="Center"
                                Command="{Binding CustomerModel.OpenSearchCustomerCommand}"/>
                        <!--Ticket end:#76072 by Pratik-->
                        <StackLayout.Triggers>
                            <DataTrigger TargetType="StackLayout"
                                         Binding="{Binding Invoice.CustomerName}"
                                         Value="Walk in">
                                <Setter Property="IsVisible"
                                        Value="false"/>
                            </DataTrigger>
                            <DataTrigger TargetType="StackLayout"
                                         Binding="{Binding Invoice.CustomerName}"
                                         Value="Cash sale">
                                <Setter Property="IsVisible"
                                        Value="false"/>
                            </DataTrigger>
                        </StackLayout.Triggers>
                    </StackLayout>
                    <Button x:Name="CustomerAddButton"
                            Text="Add Customer"
                            IsVisible="false"
                            IsEnabled="{Binding CustomerNameIsEnabled}"
                            Style="{x:Static resources:Styles.PopupSaleDetailCustomerNameButtonStyle}"
                            Command="{Binding CustomerModel.OpenSearchCustomerCommand}">
                        <!--Ticket end:#45371.by rupesh-->
                        <Button.Triggers>
                            <DataTrigger TargetType="Button"
                                         Binding="{Binding Invoice.CustomerName}"
                                         Value="Walk in">
                                <Setter Property="IsVisible"
                                        Value="true"/>
                            </DataTrigger>
                            <DataTrigger TargetType="Button"
                                         Binding="{Binding Invoice.CustomerName}"
                                         Value="Cash sale">
                                <Setter Property="IsVisible"
                                        Value="true"/>
                            </DataTrigger>
                        </Button.Triggers>
                    </Button>
                    <!--Ticket #76208 IOS:FR:Terms of payments by Pratik-->
                    <Label Text="Order Date:"
                           Margin="0,10,0,0" HeightRequest="30"
                           HorizontalOptions="FillAndExpand"
                           HorizontalTextAlignment="Center"
                           Style="{x:Static resources:Styles.InvoiceSummaryTitleLabelStyle}">
                        <Label.FormattedText>
                            <FormattedString>
                                <Span Text="Order Date:"/>
                                <Span Text=" "/>
                                <Span Text="{Binding Invoice.FinalizeDateStoreDate, StringFormat='{0:hh.mmtt, dd MMM yyyy}'}"/>
                            </FormattedString>
                        </Label.FormattedText>
                    </Label>
                    <Label Text="Order Date:" HeightRequest="30"
                           IsVisible="{Binding IsInvoiceDueDate}"
                           IsEnabled="{Binding EnableInvoiceDueDate}"
                           HorizontalOptions="FillAndExpand"
                           HorizontalTextAlignment="Center"
                           Style="{x:Static resources:Styles.InvoiceSummaryTitleLabelStyle}">
                        <Label.FormattedText>
                            <FormattedString>
                                <Span Text="Payment Due Date:"/>
                                <Span Text=" "/>
                                <Span Text="{Binding InvoiceDueDate, StringFormat='{0:dd MMM, yyyy}'}"
                                      TextColor="{x:Static resources:AppColors.HikeColor}"
                                      FontAttributes="Bold"/>
                            </FormattedString>
                        </Label.FormattedText>
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="DueDateTapGestureRecognizer_Tapped"/>
                        </Label.GestureRecognizers>
                    </Label>
