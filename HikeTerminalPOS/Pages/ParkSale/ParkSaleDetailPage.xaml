                                        Style="{x:Static resources:Styles.PopUpTextMenuButtonStylePhone}"/>
                                <!-- <Button Text="{Localize:Translate PrintText}"
                                        Padding="5,0"
                                        Command="{Binding PrintHandleClickedCommand}"
                                        Style="{x:Static resources:Styles.PopUpTextMenuButtonStylePhone}"/> -->
                                <!-- <Button Text="{Localize:Translate GiftReceiptPrintText_Phone}"
                                        Padding="5,2"
                                        Command="{Binding GiftReceiptPrintHandleClickedCommand}"
                                        Style="{x:Static resources:Styles.PopUpTextMenuButtonStylePhone}">
                                    <Button.Triggers>
                                        <DataTrigger TargetType="Button"
                                                     Binding="{Binding Invoice.Status}"
                                                     Value="4">
                                            <Setter Property="IsVisible"
                                                    Value="false"/>
                                        </DataTrigger> -->

                                        <!--Ticket start:#22406 Quote sale.by rupesh-->
                                        <!-- <DataTrigger TargetType="Button"
                                                     Binding="{Binding Invoice.Status}"
                                                     Value="11">
                                            <Setter Property="IsVisible"
                                                    Value="false"/>
                                        </DataTrigger> -->
                                        <!--Ticket end:#22406 Quote sale.by rupesh-->

                                    <!-- </Button.Triggers>
                                </Button> -->
                                <!-- <Button Text="{Localize:Translate DeliveryReceiptPrintText_Phone}"
                                        Padding="5,2"
                                        Command="{Binding DeliveryDocketReceiptPrintHandleClickedCommand}"
                                        Style="{x:Static resources:Styles.PopUpTextMenuButtonStylePhone}">
                                    <Button.Triggers>
                                        <DataTrigger TargetType="Button"
