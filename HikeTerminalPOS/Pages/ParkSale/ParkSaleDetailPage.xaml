                                        HorizontalOptions="End"/>
                                <!--Ticket end:#22406 Quote sale.by rupesh-->
                                <!--Ticket start:#58490 iPad: FR For Pick and pack option.by rupesh-->
                                <Button Text="{Localize:Translate PickAndPack}"
