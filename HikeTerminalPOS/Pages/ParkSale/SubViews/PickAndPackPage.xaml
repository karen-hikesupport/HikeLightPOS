<?xml version="1.0" encoding="UTF-8" ?>
<local:PopupBasePage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
        xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml" xmlns:local="clr-namespace:HikePOS"
		xmlns:resources="clr-namespace:HikePOS.Resources" xmlns:Localize="clr-namespace:HikePOS;assembly=HikePOS" 
		xmlns:userControls="clr-namespace:HikePOS.UserControls" xmlns:Helpers="clr-namespace:HikePOS.Helpers"
		xmlns:ios="clr-namespace:Microsoft.Maui.Controls.PlatformConfiguration.iOSSpecific;assembly=Microsoft.Maui.Controls"
		xmlns:vm="clr-namespace:HikePOS.ViewModels"
		x:DataType="vm:PickAndPackViewModel"
        xmlns:model="clr-namespace:HikePOS.Models"
        x:TypeArguments="vm:PickAndPackViewModel"
		xmlns:behaviors="clr-namespace:HikePOS.Behaviors" 
		x:Class="HikePOS.PickAndPackPage" BackgroundColor="{StaticResource PopupBG}">
	<ContentPage.Content>
			<Grid ColumnSpacing="0" RowSpacing="0">
			<Grid.RowDefinitions>
				<RowDefinition Height="*" />
			    <RowDefinition Height="{OnIdiom Phone='60',Default='0'}" />
			</Grid.RowDefinitions>
			<Grid.ColumnDefinitions>
                <ColumnDefinition Width="{OnIdiom Phone='0',Default='*'}" />
				<ColumnDefinition Width="*" />
			</Grid.ColumnDefinitions>
			<!--Ticket start:#62808 iPad:Print Receipt spacing issues. by pratik-->
		    <ContentView x:Name="PickAndPackReceiptView" Scale="0" Grid.ColumnSpan="2" HorizontalOptions="Start"/>
			<!--Ticket end:#62808 by pratik-->
		     <OnIdiom x:TypeArguments="View">
             <OnIdiom.Tablet>
			 <StackLayout Spacing="20" Grid.Row="0" Grid.Column="0" VerticalOptions="Start" HorizontalOptions="End" TranslationX="-20" TranslationY="20">
				<Button Command="{Binding CloseHandleClickedCommand}" Style="{x:Static resources:Styles.PopUpCloseButtonStyle}" HorizontalOptions="End" />
                <Button Text="{Localize:Translate SaveAndPrintButtonText}" Command="{Binding ClickedSaveCommand}"  Style="{x:Static resources:Styles.PopUpTextMenuButtonStyle}" IsEnabled="{Binding IsSaveEnabled}" HorizontalOptions="End" />
			</StackLayout>
             </OnIdiom.Tablet>
             <OnIdiom.Phone>
                 <StackLayout Spacing="20" Grid.Row="1" Grid.Column="1" Orientation="Horizontal" BackgroundColor="{x:Static resources:AppColors.MainBackgroundColor}" Padding="20,0,20,0">
                    <Button Text="Close" Command="{Binding CloseHandleClickedCommand}" Style="{x:Static resources:Styles.PopUpTextMenuButtonStylePhone}" />
				    <Button Text="{Localize:Translate SaveAndPrintButtonText}" Command="{Binding ClickedSaveCommand}"  Style="{x:Static resources:Styles.PopUpTextMenuButtonStylePhone}" IsEnabled="{Binding IsSaveEnabled}"/>
                 </StackLayout>
             </OnIdiom.Phone>
            </OnIdiom>
			<!--Start #84293 iOS - Feature:- Expand Pick & Pack & Order Full fill from multiple location by Pratik-->
				<Grid RowDefinitions="Auto,Auto,*" Margin="0" x:Name="rootview" Grid.Row="0" Grid.Column="1" RowSpacing="0" BackgroundColor="White">
					<Label Text="{Localize:Translate PickAndPack}" Style="{x:Static resources:Styles.PopupTitleLabelStyle}" />
					<VerticalStackLayout Grid.Row="1" Padding="{OnIdiom Phone='20,0,20,20',Default='40,0,40,20'}" Spacing="6" IsVisible="{Binding IsAllowFulfilment}">
						<Label Style="{x:Static resources:Styles.FormTitleLabelStyle}" HeightRequest="30" VerticalTextAlignment="End">
							<Label.FormattedText>
								<FormattedString>
									<Span Text="Select inventory outlet for fulfilment"/>
									<Span Text=" *" TextColor="Red"/>
								</FormattedString>
							</Label.FormattedText>
						</Label>
						<Border Style="{x:Static resources:Styles.FormRoundBorderStyle}" Padding="0" HeightRequest="50">
							<Grid VerticalOptions="FillAndExpand" HorizontalOptions="FillAndExpand">
								<Image Style="{x:Static resources:Styles.DropDownImageStyle}"/>
								<userControls:CustomPicker x:Name="outletspicker" IsEnabled="{Binding IsEnabledOutlets}" BackgroundColor="Transparent" ios:Picker.UpdateMode="WhenFinished"
											ItemsSource="{Binding Outlets}" DisplayProperty="Title" SelectedItem="{Binding SelectedOutlet}"
											HorizontalOptions="FillAndExpand" TextColor="{x:Static resources:AppColors.PrimaryTextColor}" />
							</Grid>
						</Border>
					</VerticalStackLayout>
					<Grid Grid.Row="2" Margin="{OnIdiom Phone='20,0',Default='40,0'}" RowSpacing="0" ColumnSpacing="6">
						<Grid.RowDefinitions>
							<RowDefinition Height="0.5" />
							<RowDefinition Height="40" />
							<RowDefinition Height="0.5" />
							<RowDefinition Height="*" />
						</Grid.RowDefinitions>
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*" />
							<ColumnDefinition Width="80" />
							<ColumnDefinition Width="120" />
						</Grid.ColumnDefinitions>

						<BoxView Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3" BackgroundColor="{x:Static resources:AppColors.NavigationBarBackgroundColor}" HeightRequest="0.5" />

						<Label Text="Items" Grid.Row="1" Grid.Column="0" FontSize="14" FontFamily="{x:Static resources:Fonts.HikeDefaultFont}" TextColor="{x:Static resources:AppColors.NavigationBarBackgroundColor}" HorizontalTextAlignment="Start" VerticalTextAlignment="Center" Margin="0,10,5,10"/>
						<Label Text="Ordered" Grid.Row="1" Grid.Column="1" FontSize="14" FontFamily="{x:Static resources:Fonts.HikeDefaultFont}" TextColor="{x:Static resources:AppColors.NavigationBarBackgroundColor}" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" Margin="0,10,5,10"/>
						<Label Text="Pack now" Grid.Row="1" Grid.Column="2" FontSize="14" FontFamily="{x:Static resources:Fonts.HikeDefaultFont}" TextColor="{x:Static resources:AppColors.NavigationBarBackgroundColor}" HorizontalTextAlignment="End" VerticalTextAlignment="Center" Margin="0,10,27,10"/>
						<BoxView Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3" BackgroundColor="{x:Static resources:AppColors.NavigationBarBackgroundColor}" HeightRequest="0.5" />
						<CollectionView x:Name="ProductsListView" Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="3" ItemsSource="{Binding InvoiceLineItems}"
										SelectionMode="None">
							<CollectionView.ItemTemplate>
								<DataTemplate x:DataType="model:InvoiceLineItemDto">
									<Grid RowSpacing="0" ColumnSpacing="6">
										<Grid.ColumnDefinitions>
											<ColumnDefinition Width="*" />
											<ColumnDefinition Width="80" />
											<ColumnDefinition Width="120" />
										</Grid.ColumnDefinitions>
										<Grid.RowDefinitions>
											<RowDefinition Height="Auto" />
											<RowDefinition Height="0.5" />
										</Grid.RowDefinitions>
										<VerticalStackLayout  Grid.Row="0" Grid.Column="0" Spacing="3" Padding="0,10">
											<Label Text="{Binding Title}" FontSize="14" FontFamily="{x:Static resources:Fonts.HikeDefaultFont}"
												TextColor="{x:Static resources:AppColors.NavigationBarBackgroundColor}"/>
											<Label FontSize="14" VerticalOptions="Start" TextColor="{x:Static resources:AppColors.NavigationBarBackgroundColor}">
												<Label.FormattedText>
													<FormattedString>
														<Span Text="Already fulfilled: " FontFamily="{x:Static resources:Fonts.HikeDefaultFont}"/>
														<Span Text="{Binding DisplayfulfillmentQuantity}" FontFamily="{x:Static resources:Fonts.HikeLightFont}"/>
													</FormattedString>
												</Label.FormattedText>
											</Label>
											<Label FontSize="14" VerticalOptions="Start" TextColor="{x:Static resources:AppColors.NavigationBarBackgroundColor}">
												<Label.FormattedText>
													<FormattedString>
														<Span Text="Available: " FontFamily="{x:Static resources:Fonts.HikeDefaultFont}"/>
														<Span Text="{Binding AvailableQuantity}" FontFamily="{x:Static resources:Fonts.HikeLightFont}"/>
													</FormattedString>
												</Label.FormattedText>
											</Label>
										</VerticalStackLayout>
										

										<Label Grid.Row="0" Grid.Column="1" Text="{Binding Quantity}" FontSize="14"
										FontFamily="{x:Static resources:Fonts.HikeLightFont}" TextColor="{x:Static resources:AppColors.NavigationBarBackgroundColor}"
										HorizontalTextAlignment="Center" VerticalOptions="Start" Margin="0,10,0,10"/>

										<!--Ticket start:#71299 iPad - Feature: Adding the stock items manually in Pick and Pack.by rupesh-->
										<HorizontalStackLayout Grid.Row="0" Grid.Column="2" HorizontalOptions="EndAndExpand" Margin="0,10,30,0" VerticalOptions="Start">
											<Label  IsVisible="{Binding IsToUpdatePickAndPack,Converter={Helpers:InverseBoolConverter}}" Text="{Binding PickAndPackQuantity}" HorizontalTextAlignment="Center" Style="{x:Static resources:Styles.TableItemLabelStyle}" HorizontalOptions="Fill" FontSize="14" TextColor="Blue">
												<Label.GestureRecognizers>
													<TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:PickAndPackViewModel}}, Path=OpenUpdateQuantityViewCommand, x:DataType=vm:PickAndPackViewModel}" CommandParameter="{x:Reference Quntity_Entry}" />
												</Label.GestureRecognizers>
												</Label>
										</HorizontalStackLayout>
										<Image Grid.Row="0" Grid.Column="2"  Source="round_check" IsVisible="{Binding IsAllQuantityScanned}" HeightRequest="20" VerticalOptions="Start" Margin="0,10" HorizontalOptions="End"/>
										<StackLayout IsVisible="{Binding IsToUpdatePickAndPack}" Grid.Row="0" Grid.Column="2" Orientation="Horizontal" HorizontalOptions="Center" BackgroundColor="White" VerticalOptions="Start">
											<Entry x:Name="Quntity_Entry" WidthRequest="70" Text="{Binding PickAndPackQuantity}" Style="{x:Static resources:Styles.FormEntryStyle}" FontFamily="{x:Static resources:Fonts.HikeDefaultFont}"
													HorizontalTextAlignment="Center" FontSize="14" Keyboard="Numeric" TextChanged="Quntity_Entry_TextChanged" Unfocused="Quntity_Entry_Unfocused" Completed="Quntity_Entry_Completed" />
										</StackLayout>
										<!--Ticket end:#71299 .by rupesh-->
										<BoxView Color="{x:Static resources:AppColors.LightBordersColor}" Grid.Row="1" Grid.Column="0" HeightRequest="0.5" Grid.ColumnSpan="3" />	
									</Grid>
								</DataTemplate>
							</CollectionView.ItemTemplate>
						</CollectionView>
					</Grid>
				</Grid>
			<!--End #84293 by Pratik-->
			</Grid>
    </ContentPage.Content>
</local:PopupBasePage>