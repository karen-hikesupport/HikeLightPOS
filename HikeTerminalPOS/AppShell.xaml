                <OnIdiom x:TypeArguments="DataTemplate" Phone="{DataTemplate local:SettingsPagePhone}" Default="{DataTemplate local:SettingsPage}" />
            </ShellContent.ContentTemplate>
    </ShellContent>

    <ShellContent x:Name="AdminMenuBtn" Route="AdminPage"
            Title="{Localize:Translate Admin_TitleText}"
            Icon="adminicon.png"
            ContentTemplate="{DataTemplate local:AdminPage}" />

