	</ItemGroup>
	<ItemGroup>
		<MauiXaml Remove="Pages\Payment\SubViews\SignaturePromptPage.xaml" />
	</ItemGroup>
	<!--	<ItemGroup Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'ios'">
	  <InterfaceDefinition Include="Resources\MauiSplash.storyboard" />
	</ItemGroup>-->
	<ItemGroup>
		<None Remove="Resources\splashscreen.svg" />
		<!--	  <None Remove="Resources\AppIcon\appiconfg.svg" />-->
		<None Remove="Messenger\" />
		<None Remove="Platforms\Android\Resources\drawable\" />
		<None Remove="Platforms\Android\Resources\drawable\splashscreen.png" />
		<None Remove="Platforms\Android\Resources\values\styles.xml" />
		<None Remove="Platforms\Android\Resources\xml\network_security_config.xml" />
		<None Remove="Platforms\Android\Resources\xml\file_paths.xml" />
	</ItemGroup>
	<ItemGroup>
		<BundleResource Include="Resources\splashscreen.png" />
		<BundleResource Include="Platforms\Android\Resources\drawable\splashscreen.png" />
	</ItemGroup>
	<ItemGroup>
		<Folder Include="Messenger\" />
		<Folder Include="Platforms\Android\Resources\drawable\" />
	</ItemGroup>
	<ItemGroup>
		<AndroidResource Include="Platforms\Android\Resources\values\styles.xml" />
		<AndroidResource Include="Platforms\Android\Resources\xml\network_security_config.xml" />
		<AndroidResource Include="Platforms\Android\Resources\xml\file_paths.xml" />
	</ItemGroup>
	<Target Name="SelectStaticRegistrar" AfterTargets="SelectRegistrar">
    <PropertyGroup Condition="'$(Registrar)' == 'managed-static'">
        <Registrar>static</Registrar>
    </PropertyGroup>
</Target>

</Project>
