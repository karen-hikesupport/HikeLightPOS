		<PackageReference Include="HtmlAgilityPack" Version="1.12.4" />
		<PackageReference Include="Sentry.Maui" Version="5.4.0" />
	</ItemGroup>
	<ItemGroup>
		<Compile Remove="Platforms\iOS\DependencyServices\MintPayment.cs" />
		<Compile Remove="Pages\Payment\SubViews\SignaturePromptPage.xaml.cs" />
	</ItemGroup>
	<ItemGroup Condition="'$(TargetFramework)' == 'net9.0-android'">
		<MauiSplashScreen Include="Resources\Images\hike_logo_login_white.svg" Color="#35BDB9" />
		<MauiIcon Include="Resources\AppIcon\appicon.svg" ForegroundFile="Resources\AppIcon\appiconfg.svg" ForegroundScale="0.60" Color="#FFFFFF" BaseSize="456,456" />
		<PackageReference Include="AndHUD" Version="2.0.2" />
		<PackageReference Include="Xamarin.AndroidX.Collection.Ktx" Version="1.5.0.2" />
		<PackageReference Include="Xamarin.AndroidX.Collection" Version="1.5.0.2" />
		<PackageReference Include="Xamarin.AndroidX.Fragment.Ktx" Version="1.8.6.1" />
		<PackageReference Include="Xamarin.AndroidX.Core" Version="1.16.0.1" />
		<PackageReference Include="FlexboxLayout.Xamarin.Android" Version="3.0.0" />
		<PackageReference Include="System.Configuration.ConfigurationManager" Version="8.0.0" />
		<PackageReference Include="Xamarin.Kotlin.StdLib" Version="2.2.0" />
	    <PackageReference Include="Xamarin.Kotlin.Reflect" Version="2.2.0" />
		<!-- <PackageReference Include="Square.OkHttp3" Version="4.12.0.7" /> -->
