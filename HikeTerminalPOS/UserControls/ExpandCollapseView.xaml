<?xml version="1.0" encoding="utf-8" ?>
<Grid xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HikePOS.UserControls.ExpandCollapseView"
            xmlns:resources="clr-namespace:HikePOS.Resources"
            xmlns:Localize="clr-namespace:HikePOS;assembly=HikePOS"
            xmlns:userControls="clr-namespace:HikePOS.UserControls"
            RowSpacing="0" ColumnSpacing="0">
    <Grid.RowDefinitions>
        <RowDefinition Height="1" />
        <RowDefinition Height="45" />
        <RowDefinition Height="1" />
        <RowDefinition Height="*" />
    </Grid.RowDefinitions>
    <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>
    <!-- <BoxView Grid.Row="0" Grid.Column="0" Color="{x:Static resources:AppColors.LightBordersColor}" VerticalOptions="End" HeightRequest="0.5" /> -->
    <StackLayout  Grid.Row="1" Grid.Column="0"  Orientation="Horizontal" HorizontalOptions="FillAndExpand" VerticalOptions="FillAndExpand">
        <Label  Text="Title" x:Name="HeaderLabel" Style="{x:Static resources:Styles.ExpandViewTitleLabelStyle}" Margin="0,5,0,5" HorizontalOptions="FillAndExpand"/>
        <Image x:Name="CollapseImage" Source="down_popup" WidthRequest="25" HeightRequest="25" VerticalOptions="Center" HorizontalOptions="End" Margin="0,5,0,5"/>
    </StackLayout>
    <Button x:Name="CollapseButton" Grid.Row="1" Grid.Column="0" BackgroundColor="Transparent" BorderWidth="0" CornerRadius="0" VerticalOptions="FillAndExpand" HorizontalOptions="FillAndExpand"/>
    <BoxView x:Name="ContainerViewTopLine" Grid.Row="2" Grid.Column="0" IsVisible="false" Color="{x:Static resources:AppColors.LightBordersColor}" VerticalOptions="End" HeightRequest="0.5"/>
    <ContentView x:Name="ContainerView" Grid.Row="3" Grid.Column="0"  IsVisible="false" VerticalOptions="FillAndExpand">
    </ContentView>
</Grid>

